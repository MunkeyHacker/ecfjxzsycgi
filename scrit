function parseMainESPColor(text)
    local lowerText = tostring(text or ""):lower()
    for name, color in pairs(MAIN_ESP_NAMED_COLORS) do
        if lowerText:find(name, 1, true) then
            return color
        end
    end

    local values = {}
    for value in lowerText:gmatch("%d+") do
        table.insert(values, tonumber(value))
    end

    if #values >= 3 then
        return Color3.fromRGB(
            math.clamp(values[1], 0, 255),
            math.clamp(values[2], 0, 255),
            math.clamp(values[3], 0, 255)
        )
    end

    return nil
end


    blue = Color3.fromRGB(80, 175, 255),
    red = Color3.fromRGB(255, 85, 85),
    green = Color3.fromRGB(85, 255, 135),
    purple = Color3.fromRGB(185, 95, 255),
    pink = Color3.fromRGB(255, 110, 190),
    orange = Color3.fromRGB(255, 170, 65),
    yellow = Color3.fromRGB(255, 230, 90),

function installGKillMouseAimHook()
    if STAND_ENABLE_MOUSE_AIM_HOOK ~= true then return end
    if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then
        warn("Mouse aim hook skipped on mobile.")
        return
    end
    if not STAND_GLOBAL_ENV or not hookmetamethod then return end
    local env = STAND_GLOBAL_ENV
    if env.STAND_GKILL_MOUSE_AIM_HOOKED then return end

    local mouse = LocalPlayer:GetMouse()
    local wrap = newcclosure or function(fn) return fn end
    local oldIndex
    oldIndex = hookmetamethod(game, "__index", wrap(function(self, key)
        local state = env.STAND_GKILL_MOUSE_AIM_STATE
        if self == mouse
            and state
            and state.active
            and state.position
            and (not checkcaller or not checkcaller()) then

            if key == "Hit" or key == "hit" then
                return CFrame.new(state.position)
            elseif key == "Target" or key == "target" then
                return state.targetPart
            end
        end

        return oldIndex(self, key)
    end))

    env.STAND_GKILL_MOUSE_AIM_HOOKED = true
end

installGKillMouseAimHook()

function isAimLineBlocked(fromPosition, aimPosition, target)
    if not fromPosition or not aimPosition then return false end

    local direction = aimPosition - fromPosition
    if direction.Magnitude < 1 then return false end

    STAND_RAYCAST_PARAMS.FilterDescendantsInstances = {
        LocalPlayer.Character,
        getWorldCharacter(target),
    }

    return Workspace:Raycast(fromPosition, direction, STAND_RAYCAST_PARAMS) ~= nil
end

function getBestAimPart(target, char)
    local originRoot = getRoot(LocalPlayer.Character)
    local origin = originRoot and originRoot.Position or (Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.Position)

    for _, partName in ipairs({ "Head", "UpperTorso", "Torso", "HumanoidRootPart", "LowerTorso" }) do
        local part = char:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            local testPos = part.Position + Vector3.new(0, math.clamp(part.Size.Y * 0.1, 0.15, 0.65), 0)
            if not origin or not isAimLineBlocked(origin, testPos, target) then
                return part
            end
        end
    end

    return char:FindFirstChild("UpperTorso")
        or char:FindFirstChild("Torso")
        or getRoot(char)
        or char:FindFirstChild("Head")
end

function STAND_MOVEMENT_ASSIST_ACTIVE()
    return type(STAND_MOVEMENT_ASSIST) == "table" and STAND_MOVEMENT_ASSIST.Active == true
end

function STAND_GET_MOVEMENT_ASSIST_PART(target, char)
    if not STAND_MOVEMENT_ASSIST_ACTIVE() or not char then return nil end

    local partName = tostring(STAND_MOVEMENT_ASSIST.PriorityLimb or "HumanoidRootPart")
    local part = char:FindFirstChild(partName)
    if not part or not part:IsA("BasePart") then return nil end

    if STAND_MOVEMENT_ASSIST.ObstacleScan then
        local originRoot = getRoot(LocalPlayer.Character)
        local origin = originRoot and originRoot.Position or (Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.Position)
        if origin and isAimLineBlocked(origin, part.Position, target) then
            return nil
        end
    end

    return part
end

function STAND_RESOLVE_TARGET_VELOCITY(targetChar, aimPart, targetRoot)
    local root = targetChar and targetChar:FindFirstChild(tostring(STAND_MOVEMENT_ASSIST.PriorityLimb or "HumanoidRootPart"))
    if not root or not root:IsA("BasePart") then
        root = targetRoot or aimPart
    end
    if not root or not root:IsA("BasePart") then
        return Vector3.zero
    end

    local legacyVelocity = root.Velocity
    local assemblyVelocity = root.AssemblyLinearVelocity
    local resolvedVelocity = legacyVelocity:Lerp(assemblyVelocity, 0.65)
    if legacyVelocity.Magnitude > 50 then
        resolvedVelocity *= 0.75
    end

    return resolvedVelocity
end

function getAimPosition(target)
    local char = getWorldCharacter(target)
    if not char then return nil, nil end

    local aimPart = STAND_GET_MOVEMENT_ASSIST_PART(target, char) or getBestAimPart(target, char)

    if aimPart and aimPart:IsA("BasePart") then
        local myRoot = getRoot(LocalPlayer.Character)
        local targetRoot = getRoot(char)
        local heightOffset = aimPart.Name == "Head" and 0 or math.clamp(aimPart.Size.Y * 0.18, 0.25, 0.95)
        local basePosition = aimPart.Position + Vector3.new(0, heightOffset, 0)
        local distance = myRoot and (myRoot.Position - basePosition).Magnitude or 40
        local partVelocity = aimPart.AssemblyLinearVelocity
        local rootVelocity = targetRoot and targetRoot.AssemblyLinearVelocity or Vector3.zero
        local velocity = rootVelocity.Magnitude >= partVelocity.Magnitude and rootVelocity or partVelocity
        if STAND_MOVEMENT_ASSIST_ACTIVE() then
            local resolvedVelocity = STAND_RESOLVE_TARGET_VELOCITY(char, aimPart, targetRoot)
            if resolvedVelocity.Magnitude > 0.05 then
                velocity = resolvedVelocity
            end
        end
        local key = target.UserId or target.Name
        local now = time()
        local previous = STAND_AIM_TRACK[key]
        if previous and previous.velocity then
            velocity = previous.velocity:Lerp(velocity, AIM_VELOCITY_SMOOTH_ALPHA)
        end

        velocity = Vector3.new(velocity.X, math.clamp(velocity.Y, -34, 34), velocity.Z)
        local flatSpeed = Vector3.new(velocity.X, 0, velocity.Z).Magnitude
        local projectileSpeed = flatSpeed >= AIM_FAST_SPEED and AIM_FAST_PROJECTILE_SPEED or AIM_NORMAL_PROJECTILE_SPEED
        local maxLeadTime = flatSpeed >= 125 and 0.36 or (flatSpeed >= AIM_FAST_SPEED and 0.29 or 0.2)
        local minLeadTime = flatSpeed >= AIM_FAST_SPEED and 0.045 or 0.032
        local leadTime = math.clamp(distance / projectileSpeed, minLeadTime, maxLeadTime)
        if STAND_MOVEMENT_ASSIST_ACTIVE() then
            leadTime = math.max(leadTime, math.clamp(tonumber(STAND_MOVEMENT_ASSIST.OffsetFactor) or 0.122, minLeadTime, maxLeadTime))
        end
        local totalLead = velocity * leadTime

        if previous and previous.position and previous.velocity and previous.time then
            local dt = now - previous.time
            local positionJump = (basePosition - previous.position).Magnitude
            if dt > 0.015 and dt < 0.4 and positionJump < 90 then
                local acceleration = (velocity - previous.velocity) / dt
                local accelerationLead = acceleration * leadTime * leadTime * AIM_ACCEL_LEAD_SCALE
                if accelerationLead.Magnitude > AIM_MAX_LEAD_DISTANCE * 0.22 then
                    accelerationLead = accelerationLead.Unit * AIM_MAX_LEAD_DISTANCE * 0.22
                end
                totalLead += accelerationLead
            end
        end

        STAND_AIM_TRACK[key] = {
            position = basePosition,
            velocity = velocity,
            time = now,
        }

        if totalLead.Magnitude > AIM_MAX_LEAD_DISTANCE then
            totalLead = totalLead.Unit * AIM_MAX_LEAD_DISTANCE
        end
        return basePosition + totalLead, aimPart
    end

    return nil, nil
end

function aimAtTarget(target, aimPos, aimPart)

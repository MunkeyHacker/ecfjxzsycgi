function STAND_START_GUNKILL_COMMAND(target, isLoop)
    if not target or target == LocalPlayer then return false end

    local signature = (isLoop and "glk|" or "gk|") .. tostring(target.UserId or target.Name)
    local now = time()
    if gkillEnabled
        and currentGTarget == target
        and gloopkillEnabled == (isLoop == true) then
        print("Gun Kill already active on " .. target.Name)
        return true
    end
    if gkillState == "reloading"
        and reloadResumeTarget == target
        and reloadResumeLoop == (isLoop == true) then
        print("Gun Kill reload already active on " .. target.Name)
        return true
    end

    STAND_LAST_COMBAT_COMMAND_KEY = signature
    STAND_LAST_COMBAT_COMMAND_TIME = now
    STAND_CANCEL_TRANSIENT_ACTIONS_FOR_COMBAT()
    startGunKill(target, isLoop == true)
    return true
end

startGunKill = nil

function reloadToolUntilFull(toolName, thisReloadToken)
    if not toolName then return false end

    local started = time()
    while thisReloadToken == reloadToken and time() - started <= RELOAD_PER_GUN_TIME do
        local tool = findInventoryTool(toolName)
        if toolAmmoIsFull(tool) then
            return true
        end

        lastEquipAttempt = 0
        tool = equipAnyGun(toolName, false)
        if not tool then
            return false
        end

        currentGun = tool
        currentGunName = tool.Name
        pressReloadKey()
        task.wait(RELOAD_KEY_SPAM_INTERVAL)
    end

    return toolAmmoIsFull(findInventoryTool(toolName))
end

function tryReloadGuns(preferredName, thisReloadToken)
    local reloadedAny = false
    for _, toolName in ipairs(getReloadGunNames(preferredName)) do
        if thisReloadToken ~= reloadToken then
            break
        end

        local tool = findInventoryTool(toolName)
        if isGunTool(tool) and not toolAmmoIsFull(tool) then
            reloadedAny = true
            reloadToolUntilFull(toolName, thisReloadToken)
        end
    end

    if not reloadedAny and preferredName then
        lastEquipAttempt = 0
        equipAnyGun(preferredName, false)
        pressReloadKey()
    end
end

reloadInventorySafely = function(preferredName, returnCFrame, afterReload)
    if not STAND_LOCAL_ALIVE() then return end

    if gkillEnabled and hardReloadGun then
        hardReloadGun(preferredName)
        return
    end

    reloadToken += 1
    local thisReloadToken = reloadToken
    reloadUntil = time() + RELOAD_PAUSE_TIME
    startSafeSpotSwitching()

    task.spawn(function()
        tryReloadGuns(preferredName or currentGunName, thisReloadToken)
        if thisReloadToken ~= reloadToken then return end

        reloadUntil = 0
        stopSafeSpotSwitching()
        releaseCharacterControl()

        local root = getRoot(LocalPlayer.Character)
        if root and returnCFrame and not isFollowing and not gkillEnabled then
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
            root.CFrame = returnCFrame
        elseif isFollowing and not gkillEnabled and not loopkillEnabled then
            returnToMainFollow()
        end

        if afterReload then
            task.defer(afterReload)
        end
    end)
end

hardReloadGun = function(forcedReloadGunName)
    if not gkillEnabled then return end
    if not STAND_LOCAL_ALIVE() then return end

    reloadToken += 1
    local thisReloadToken = reloadToken
    local thisGunSession = gunSessionToken
    local resumeFollowToken = followResumeToken
    reloadUntil = time() + RELOAD_PAUSE_TIME
    reloadResumeTarget = currentGTarget
    reloadResumeLoop = gloopkillEnabled

    gunConnection = disconnect(gunConnection)
    stopStrafing()
    startSafeSpotSwitching()
    gkillEnabled = false
    gkillState = "reloading"
    clearGKillMouseAim()

    local reloadGunName = forcedReloadGunName or currentGunName
    task.spawn(function()
        tryReloadGuns(reloadGunName, thisReloadToken)
        if thisReloadToken ~= reloadToken or thisGunSession ~= gunSessionToken then return end
        reloadUntil = 0
        if reloadResumeTarget and reloadResumeTarget.Parent == Players and (isAlive(reloadResumeTarget) or reloadResumeLoop) then
            local resumeTarget = reloadResumeTarget
            local resumeLoop = reloadResumeLoop
            reloadResumeTarget = nil
            stopSafeSpotSwitching()
            releaseCharacterControl()
            startGunKill(resumeTarget, resumeLoop, true, true, thisGunSession)
        elseif wasFollowingMainBeforeGun and resumeFollowToken == followResumeToken then
            reloadResumeTarget = nil
            stopSafeSpotSwitching()
            releaseCharacterControl()
            returnToMainFollow()
        else
            reloadResumeTarget = nil
            stopSafeSpotSwitching()
            releaseCharacterControl()
            gkillState = "off"
        end
    end)
end

startGunKill = function(target, isLoop, preserveGunName, skipPreReload, sessionToken)
    if not target or target == LocalPlayer then return end
    if not STAND_LOCAL_ALIVE() then return end
    if bringDeliveryTargetName and target.Name ~= bringDeliveryTargetName then
        clearBringDelivery()
    end

    if not sessionToken then
        if gkillEnabled then
            stopGunKill(false)
        end
        gunConnection = disconnect(gunConnection)
        cleanupGunTargetConnections()
        stopStrafing()
        stopSafeSpotSwitching()
        STAND_RESET_CAMERA_TO_SELF()
        reloadToken += 1
        grabTaskToken += 1
        stompTaskToken += 1
        stompBusy = false
        currentGTarget = nil
        currentGTargetName = nil
        currentGun = nil
        currentGunName = nil
        gunSessionToken += 1
        followResumeToken += 1
        sessionToken = gunSessionToken
    elseif sessionToken ~= gunSessionToken then
        return
    end

    if gkillEnabled and not skipPreReload then
        stopGunKill(false)
        gunSessionToken += 1
        sessionToken = gunSessionToken
    end
    stopSafeSpotSwitching()

    if not skipPreReload and not preserveGunName and reloadInventorySafely then
        local root = getRoot(LocalPlayer.Character)
        local returnCFrame = root and root.CFrame or nil
        local thisGunSession = sessionToken
        reloadInventorySafely(currentGunName, returnCFrame, function()
            if thisGunSession == gunSessionToken and target and target.Parent == Players then
                startGunKill(target, isLoop, preserveGunName, true, thisGunSession)
            end
        end)
        return
    end

    currentGTarget = target
    currentGTargetName = target.Name
    STAND_AIM_TRACK[target.UserId or target.Name] = nil
    gkillEnabled = true
    gloopkillEnabled = isLoop == true
    gkillState = "attacking"
    lastGunFire = 0
    STAND_TRY_MOBILE_FOCUS(true)

    local main = getMainPlayer()
    wasFollowingMainBeforeGun = isFollowing and followTarget == main and main ~= nil

    if not preserveGunName then
        currentGunName = nil
    end
    lastEquipAttempt = 0

    if not equipAnyGun(currentGunName) and not gloopkillEnabled then
        stopGunKill(false)
        return
    end

    watchTarget(target)

    if isAlive(target) then
        startStrafing(target)
    end

    gunConnection = track(RunService.RenderStepped:Connect(function()
        if sessionToken ~= gunSessionToken then
            gunConnection = disconnect(gunConnection)
            return
        end
        if not gkillEnabled or not currentGTarget then return end
        if gkillState == "carrying" or gkillState == "flinging" then return end

        if gloopkillEnabled and currentGTarget.Parent ~= Players and currentGTargetName then
            local foundTarget = Players:FindFirstChild(currentGTargetName)
            if foundTarget then
                currentGTarget = foundTarget
                watchTarget(foundTarget)
            end
        end

        if gloopkillEnabled and gkillState == "waiting" then
            if currentGTarget.Character and isAlive(currentGTarget) and not isTargetKO(currentGTarget) then
                gkillState = "attacking"
                lastGunFire = 0
                STAND_TRY_MOBILE_FOCUS(true)
                lastEquipAttempt = 0
                equipAnyGun(currentGunName)
                stopSafeSpotSwitching()
                startStrafing(currentGTarget)
            end
            return
        end

        if isTargetKO(currentGTarget) then
            handleTargetKO(currentGTarget)
            return
        end

        if not currentGTarget.Character or not isAlive(currentGTarget) then
            handleTargetDown()
            return
        end

        local aimPos, aimPart = aimAtTarget(currentGTarget)

        fireEquippedTool(currentGTarget, aimPos, aimPart)

        if gkillState == "attacking" and not activelyStrafing then
            startStrafing(currentGTarget)
        end
    end))

    print("Gun Kill started on " .. target.Name .. (isLoop and " [LOOP]" or ""))
end

track(UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == STAND_STATUS_TOGGLE_KEY then
        STAND_TOGGLE_STATUS_GUI()
        return
    end
    if gameProcessed and input.KeyCode ~= Enum.KeyCode.R then return end
    if input.KeyCode == Enum.KeyCode.R and gkillEnabled then
        hardReloadGun()
    end

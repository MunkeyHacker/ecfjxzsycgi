function canUseGunCandidate(tool, requireAmmo, skipName)
    if not tool or not tool.Parent then return false end
    if not isGunTool(tool) then return false end
    if skipName and tool.Name == skipName then return false end
    return not requireAmmo or toolHasAmmo(tool)
end


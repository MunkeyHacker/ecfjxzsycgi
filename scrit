            STAND_GKILL_MODE = requestedMode
        end

        if STAND_GKILL_MODE == STAND_GKILL_MODE_FLING then
            print("Mode 1 active -> !gkill guns target, then uses !kill fling logic")
        else
            print("Mode 2 active -> current !gkill logic (gun kill + KO pickup)")
        end

    elseif cmd == "fmode" then
        local requestedMode = tonumber(tostring(argText or ""):match("%d+"))
        if requestedMode == 1 or requestedMode == 2 or requestedMode == 3 then
            STAND_FOLLOW_ANIM_MODE = requestedMode
        end
        if STAND_FOLLOW_ANIM_MODE == 3 then
            print("Follow animation mode 3 -> active emote while moving, idle fallback")
        elseif STAND_FOLLOW_ANIM_MODE == 2 then
            print("Follow animation mode 2 -> idle animation while moving")
        else
            STAND_FOLLOW_ANIM_MODE = 1
            print("Follow animation mode 1 -> normal movement animations")
        end

    elseif cmd == "food" then
        STAND_RUN_FOOD_COMMAND(argText or "use")

    elseif cmd == "unfood" then
        STAND_SET_AUTO_FOOD(false)

    elseif cmd == "stop" then
        STAND_STOP_ALL_ACTIONS()

    elseif cmd == "emote" then
        if not argText then
            print("Emotes: " .. STAND_GET_EMOTE_LIST_TEXT())
        else
            local emoteArg = tostring(argText):match("^%s*(.-)%s*$")
            local ok, result = pcall(function()
                return STAND_PLAY_EMOTE(emoteArg)
            end)
            if not ok then
                warn("Emote command failed -> " .. tostring(result))
                print("Emote failed")
            elseif not result then
                print("Emote failed")
            end
        end

    elseif cmd == "unemote" then
        STAND_STOP_EMOTE()
        print("Emote stopped")

    elseif cmd == "target" then
        local lowerArg = tostring(argText or ""):lower()
        if lowerArg == "clear" or lowerArg == "off" or lowerArg == "none" then
            setSelectedTarget(nil)
            targetViewEnabled = false
            targetESPEnabled = false
            clearTargetESP()
            STAND_RESET_CAMERA_TO_SELF()
            print("Selected target cleared")
        else
            local target = getPlayer(argText)
            if target then
                setSelectedTarget(target)
                print("Selected target -> " .. target.Name)
            elseif selectedTargetName then
                print("Selected target -> " .. selectedTargetName)
            else
                print("No selected target")
            end
        end

    elseif cmd == "view" then
        local target = getPlayer(argText)
        if target then
            setSelectedTarget(target)
        end
        if viewSelectedTarget() then
            print("Viewing -> " .. (selectedTargetName or "target"))
        else
            print("No selected target to view")
        end

    elseif cmd == "unview" then
        unviewTarget()
        print("View reset")

    elseif cmd == "goto" then
        local target = getPlayer(argText)
        if target then
            setSelectedTarget(target)
        end
        if gotoSelectedTarget() then
            print("Goto -> " .. (selectedTargetName or "target"))
        else
            print("No selected target to goto")
        end

    elseif cmd == "kill" or cmd == "k" then
        local target = STAND_GET_COMMAND_TARGET(argText)
        if target then
            if gkillEnabled then
                stopGunKill(false)
            end
            STAND_CANCEL_TRANSIENT_ACTIONS_FOR_COMBAT()
            setSelectedTarget(target)
            local restoreFollow = isFollowing
            clearFollow()
            local resumeFollowToken = followResumeToken
            if fling(target) then
                task.delay(FLING_DURATION + 0.2, function()
                    if restoreFollow and resumeFollowToken == followResumeToken and not loopkillEnabled and not gkillEnabled then
                        returnToMainFollow()
                    end
                end)
            elseif restoreFollow and resumeFollowToken == followResumeToken then
                returnToMainFollow()
            end
        end

    elseif cmd == "loopkill" or cmd == "lk" then
        local target = STAND_GET_COMMAND_TARGET(argText)
        if target then
            if gkillEnabled then
                stopGunKill(false)
            end
            STAND_CANCEL_TRANSIENT_ACTIONS_FOR_COMBAT()
            setSelectedTarget(target)
            local restoreLoopFollow = isFollowing
            clearFollow()
            wasFollowingBeforeLoopkill = restoreLoopFollow
            loopkillTarget = target
            loopkillTargetName = target.Name
            loopkillEnabled = true
            lastLoopFling = 0
        end

    elseif cmd == "unloopkill" or cmd == "ulk" or cmd == "unlk" then
        loopkillEnabled = false
        loopkillTarget = nil
        loopkillTargetName = nil
        if wasFollowingBeforeLoopkill then
            returnToMainFollow()
        end
        wasFollowingBeforeLoopkill = false

    elseif cmd == "bring" or cmd == "b" then
        if gkillEnabled then
            stopGunKill(false)
        end
        STAND_CANCEL_TRANSIENT_ACTIONS_FOR_COMBAT()
        stopSafeSpotSwitching()
        local myRoot = getRoot(LocalPlayer.Character)
        if sender and sender.Name == STAND_GET_COMMAND_OWNER_NAME() then
            local mainRoot = getRoot(getWorldCharacter(sender))
            if myRoot and mainRoot then
                myRoot.AssemblyLinearVelocity = Vector3.zero
                myRoot.AssemblyAngularVelocity = Vector3.zero
                myRoot.CFrame = mainRoot.CFrame * CFrame.new(0, 3.5, -5)
                print("Bring -> came to main")
            end
        elseif myRoot then
            local deliveryCFrame = myRoot.CFrame
            if not startBringMainToCFrame(deliveryCFrame) then
                print("Bring failed -> main not found")
            end
        end

    elseif cmd == "follow" then
        local target = getPlayer(argText) or getMainPlayer()
        if target then
            if gkillEnabled then
                stopGunKill(false)
            end
            loopkillEnabled = false
            loopkillTarget = nil
            loopkillTargetName = nil
            wasFollowingBeforeLoopkill = false
            STAND_START_FOLLOW_TARGET(target, true)
        end

    elseif cmd == "unfollow" then
        clearFollow()
        wasFollowingBeforeLoopkill = false
        print("Stopped following")

    elseif cmd == "vanish" or cmd == "hide" then
        if gkillEnabled then
            stopGunKill(false)
        end
        STAND_CANCEL_TRANSIENT_ACTIONS_FOR_COMBAT()
        clearFollow()
        wasFollowingBeforeLoopkill = false
        goSafeSpot()

    elseif cmd == "appear" then
        if gkillEnabled then
            stopGunKill(false)
        end
        STAND_CANCEL_TRANSIENT_ACTIONS_FOR_COMBAT()
        wasFollowingBeforeLoopkill = false
        STAND_GO_UNSAFE()

    elseif cmd == "annoy" then
        if not ANNOY_COMMANDS_ENABLED then
            STAND_STOP_ANNOY()
            print("Annoy disabled")
        else
            local target = STAND_GET_COMMAND_TARGET(argText)
            if target then
                STAND_START_ANNOY(target)
            else
                print("No target to annoy")
            end
        end

    elseif cmd == "unannoy" then
        STAND_STOP_ANNOY()

    elseif cmd == "gkill" or cmd == "gk" or cmd == "gunkill" then
        local target = STAND_GET_COMMAND_TARGET(argText)
        if target then
            setSelectedTarget(target)
            STAND_START_GUNKILL_COMMAND(target, false)
        end

    elseif cmd == "gloopkill" or cmd == "glk" or cmd == "lgkill" or cmd == "lgk" or cmd == "loopgkill" or cmd == "loopgunkill" then
        local target = STAND_GET_COMMAND_TARGET(argText)
        if target then
            setSelectedTarget(target)
            STAND_START_GUNKILL_COMMAND(target, true)
        end

    elseif cmd == "ungkill" or cmd == "ungloopkill" or cmd == "unglk" or cmd == "stopgkill" then
        stopGunKill(false)
        print("Gun Kill stopped")

    elseif cmd == "stomp" then
        autoStompEnabled = true
        print("Post-gkill stomp enabled")

    elseif cmd == "unstomp" then
        autoStompEnabled = false
        stompTaskToken += 1
        stompBusy = false
        print("Post-gkill stomp disabled")

    elseif cmd == "esp" or cmd == "mainesp" then
        local target = getPlayer(argText)
        if target then
            setSelectedTarget(target)
            argText = nil
        end
        local parsedColor = parseMainESPColor(argText)
        if selectedTargetName then
            setTargetESPEnabled(true, parsedColor)
            print("Target ESP enabled -> " .. selectedTargetName)
        else
            if parsedColor then
                mainESPColor = parsedColor
            end
            setMainESPEnabled(true)
            print("Main ESP enabled")
        end

    elseif cmd == "unesp" or cmd == "noesp" or cmd == "unmainesp" then
        if selectedTargetName then
            setTargetESPEnabled(false)
            print("Target ESP disabled")
        else
            setMainESPEnabled(false)
            print("Main ESP disabled")
        end

    elseif cmd == "render" then
        setRendering(true)

    elseif cmd == "unrender" then
        setRendering(false)

    elseif cmd == "aimhook" then
        local arg = tostring(argText or ""):match("^%s*(.-)%s*$"):lower()
        if arg == "on" or arg == "true" or arg == "1" then
            if STAND_IS_MOBILE_PROFILE then
                STAND_ENABLE_MOUSE_AIM_HOOK = false

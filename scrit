    safeSpotConnection = disconnect(safeSpotConnection)
end

function startSafeSpotSwitching()
    stopSafeSpotSwitching()
    isFlying = true
    followTargetMoving = false
    createCustomAnimation(LocalPlayer.Character)

    local nextSwitch = 0
    local lastIndex = nil
    safeSpotConnection = track(RunService.Heartbeat:Connect(function()
        local root = getRoot(LocalPlayer.Character)
        if not root then
            return
        end

        local humanoid = getHumanoid(LocalPlayer.Character)
        if humanoid then
            pcall(function()
                humanoid.Sit = false
                humanoid.PlatformStand = true
                humanoid.AutoRotate = false
            end)
        end

        local now = time()
        if now >= nextSwitch then
            local index = math.random(1, #SAFE_SPOTS)
            if #SAFE_SPOTS > 1 and index == lastIndex then
                index = (index % #SAFE_SPOTS) + 1
            end
            lastIndex = index
            local jitter = Vector3.new(
                math.random(-650, 650),
                math.random(0, 950),
                math.random(-650, 650)
            )
            local lookVector = root.CFrame.LookVector
            if lookVector.Magnitude < 0.1 then
                lookVector = Vector3.new(0, 0, -1)
            end
            local targetPosition = SAFE_SPOTS[index].Position + jitter
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
            root.CFrame = CFrame.new(targetPosition, targetPosition + lookVector)
            nextSwitch = now + SAFE_SPOT_SWITCH_INTERVAL
        end
    end))
end


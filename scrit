function buyFullArmor()
    if armorBusy then return end
    STAND_ARMOR_BUY_TOKEN += 1
    local thisArmorToken = STAND_ARMOR_BUY_TOKEN
    armorBusy = true

    task.spawn(function()
        local item = getArmorShopItem()
        local clickDetector = item and item:FindFirstChildOfClass("ClickDetector")
        local head = item and item:FindFirstChild("Head")
        local root = getRoot(LocalPlayer.Character)
        local buyCFrame = head and head.CFrame
        local canClickBuy = item and clickDetector and head and root and buyCFrame

        local wasFollowing = isFollowing
        local oldCFrame = root and root.CFrame
        local humanoid = getHumanoid(LocalPlayer.Character)
        local oldPlatformStand = humanoid and humanoid.PlatformStand

        if getArmorValue() and getArmorValue() >= ARMOR_FULL_VALUE then
            lastArmorBuy = time()
            armorBusy = false
            return
        end

        if not canClickBuy then
            lastArmorBuy = time() - ARMOR_BUY_COOLDOWN + 5
            armorBusy = false
            return
        end

        pcall(function()
            clickDetector.MaxActivationDistance = math.max(clickDetector.MaxActivationDistance, 32)
        end)

        clearFollow()
        local resumeFollowToken = followResumeToken
        stopSafeSpotSwitching()

        if humanoid then
            pcall(function()
                humanoid.PlatformStand = true
            end)
        end

        for _ = 1, ARMOR_BUY_ATTEMPTS do
            if thisArmorToken ~= STAND_ARMOR_BUY_TOKEN or gkillEnabled or loopkillEnabled then
                break
            end
            if getArmorValue() and getArmorValue() >= ARMOR_FULL_VALUE then
                break
            end

            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
            root.CFrame = buyCFrame
            task.wait(ARMOR_BUY_CLICK_DELAY)
            pcall(function()
                fireclickdetector(clickDetector)
            end)
            task.wait(ARMOR_BUY_CLICK_DELAY)
        end

        if root and root.Parent then
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
            if oldCFrame then
                root.CFrame = oldCFrame
            end
        end
        if humanoid and humanoid.Parent then
            pcall(function()
                humanoid.PlatformStand = oldPlatformStand
            end)
        end
        if wasFollowing
            and thisArmorToken == STAND_ARMOR_BUY_TOKEN
            and resumeFollowToken == followResumeToken
            and not gkillEnabled
            and not loopkillEnabled then
            returnToMainFollow()
        end

        lastArmorBuy = time()
        armorBusy = false
    end)
end


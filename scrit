        end

        foodBusy = false
    end)
end

function STAND_TRY_USE_FOOD(forceUse)
    if not forceUse and not AUTO_EAT_FOOD then return false, "off" end
    if foodBusy then return false, "busy" end
    if time() - lastFoodUse < FOOD_USE_COOLDOWN then return false, "cooldown" end
    if gkillState == "carrying" or flingBusy or armorBusy then return false, "busy" end

    local health = getHealthValue()
    if not health or health <= 0 then return false, "dead" end

    local foodTool = STAND_CHOOSE_FOOD_TOOL(health)
    if forceUse and not foodTool then
        foodTool = STAND_FIND_ANY_FOOD_TOOL()
    end

    if foodTool then
        STAND_USE_FOOD_TOOL(foodTool)
        return true, foodTool.Name
    end

    return false, "no food"
end


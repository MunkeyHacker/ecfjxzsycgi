    local seen = {}

    for _, weaponName in ipairs(WEAPON_PRIORITY) do
        addGunCandidate(STAND_WEAPON_CACHE, seen, findInventoryTool(weaponName))
    end

    for _, container in ipairs(getInventoryContainers()) do

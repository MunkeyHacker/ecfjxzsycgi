            if isGunTool(tool) then
                seen[name] = true
                table.insert(names, name)
            end
        end
    end

    addName(preferredName)
    for _, tool in ipairs(getWeaponCandidates()) do
        addName(tool.Name)
    end

    return names
end

function equipAnyGun(preferredName, requireAmmo, skipName)
    if not STAND_LOCAL_ALIVE() then return nil end

    local requireLoaded = requireAmmo == true
    local now = time()
    if now - lastEquipAttempt < EQUIP_RETRY_INTERVAL then
        local equipped = getEquippedTool()
        if canUseGunCandidate(equipped, requireLoaded, skipName) and (not preferredName or equipped.Name == preferredName) then
            return equipped
        end
        return nil
    end
    lastEquipAttempt = now

    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    local character = LocalPlayer.Character
    local humanoid = getHumanoid(character)
    if not backpack or not character or not humanoid then return nil end

    local equipped = getEquippedTool()
    if canUseGunCandidate(equipped, requireLoaded, skipName) and (not preferredName or equipped.Name == preferredName) then
        currentGun = equipped
        currentGunName = equipped.Name
        return equipped
    end

    local tool = nil
    if not preferredName and not requireLoaded then
        tool = findBackpackTool(nil, true, skipName)
    end
    if not tool then
        tool = findBackpackTool(preferredName, requireLoaded, skipName)
    end
    if not tool and requireLoaded then
        return nil
    end
    if not tool then
        tool = findBackpackTool(preferredName, false, skipName)
    end
    if not tool then
        warn("No gun tool found in backpack or character.")
        return nil
    end

    if tool.Parent ~= character then

    for _, partName in ipairs({ "UpperTorso", "Torso", "LowerTorso", "Head" }) do
        local part = char:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            return part
        end
    end

    local bestPart = nil
    local bestSize = 0
    for _, part in ipairs(char:GetChildren()) do
        if part:IsA("BasePart")
            and part.Name ~= "HumanoidRootPart"
            and not part.Name:lower():find("hitbox", 1, true) then
            local sizeScore = part.Size.X + part.Size.Y + part.Size.Z
            if sizeScore > bestSize then
                bestSize = sizeScore
                bestPart = part

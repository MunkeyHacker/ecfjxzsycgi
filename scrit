function normalizeCommand(cmd)
    return COMMAND_ALIASES[cmd] or cmd
end

function STAND_GET_COMMAND_OWNER_NAME()
    return tostring(STAND_COMMAND_OWNER_NAME or MAIN_USERNAME)
end

function STAND_SET_COMMAND_OWNER(player)
    if not player or player == LocalPlayer then return false end

    STAND_COMMAND_OWNER_NAME = player.Name
    if STAND_GLOBAL_ENV then
        STAND_GLOBAL_ENV.STAND_COMMAND_OWNER_NAME = STAND_COMMAND_OWNER_NAME
    end
    STAND_CACHED_MAIN_PLAYER = player
    STAND_MARK_PLAYER_CACHE_DIRTY()
    watchMainDeathSafespot()
    print("Command owner -> " .. STAND_COMMAND_OWNER_NAME)
    return true
end

function isCommandSender(sender)
    return sender and (sender.Name == STAND_GET_COMMAND_OWNER_NAME() or sender == LocalPlayer)
end

function STAND_PREFIX_STARTS_COMMAND(text, prefixIndex)
    local rawCommand = text:sub(prefixIndex + #PREFIX):match("^%s*(%S+)")
    rawCommand = rawCommand and rawCommand:lower() or nil
    return rawCommand and COMMAND_ALIASES[rawCommand] ~= nil
end

function STAND_FIND_NEXT_STACK_PREFIX(text, searchStart)
    while true do
        local index = text:find(PREFIX, searchStart, true)
        if not index then return nil end
        if STAND_PREFIX_STARTS_COMMAND(text, index) then
            return index
        end
        searchStart = index + #PREFIX
    end
end

function STAND_SPLIT_STACKED_COMMANDS(message)
    local chunks = {}
    local searchStart = 1
    local text = tostring(message or "")
    while true do
        local startIndex = STAND_FIND_NEXT_STACK_PREFIX(text, searchStart)
        if not startIndex then
            break
        end

        local nextIndex = STAND_FIND_NEXT_STACK_PREFIX(text, startIndex + #PREFIX)
        local chunk = text:sub(startIndex, nextIndex and (nextIndex - 1) or #text):match("^%s*(.-)%s*$")
        if chunk and chunk ~= "" and chunk ~= PREFIX then
            table.insert(chunks, chunk)
        end

        if not nextIndex then
            break
        end
        searchStart = nextIndex
    end
    return chunks
end

function STAND_GET_STACK_COMMAND(chunk)
    local text = tostring(chunk or "")
    if text:sub(1, #PREFIX) == PREFIX then
        text = text:sub(#PREFIX + 1)
    end
    local rawCommand = (text:match("^%s*(%S+)") or ""):lower()
    return normalizeCommand(rawCommand)
end

function STAND_COMMAND_IS_COMBAT(cmd)
    return cmd == "kill"
        or cmd == "loopkill"
        or cmd == "gkill"
        or cmd == "gloopkill"
        or cmd == "annoy"
end

function STAND_SHOULD_IGNORE_MIRRORED_COMMAND(message, sender)
    local normalized = tostring(message or ""):lower():gsub("%s+", " "):match("^%s*(.-)%s*$") or ""
    local senderKey = tostring(sender and (sender.UserId or sender.Name) or "")
    local now = time()

    if STAND_LAST_ANY_COMMAND_KEY == normalized
        and STAND_LAST_ANY_COMMAND_SENDER ~= senderKey
        and now - STAND_LAST_ANY_COMMAND_TIME < 1.25 then
        return true
    end

    STAND_LAST_ANY_COMMAND_KEY = normalized
    STAND_LAST_ANY_COMMAND_TIME = now
    STAND_LAST_ANY_COMMAND_SENDER = senderKey
    return false
end

function STAND_WAIT_AFTER_STACK_COMMAND(cmd, nextCmd)
    if not nextCmd or nextCmd == "" then return end

    if (cmd == "gkill" or cmd == "gloopkill") and STAND_COMMAND_IS_COMBAT(nextCmd) then
        local started = time()
        repeat
            task.wait(0.2)
        until not gkillEnabled
            or gkillState == "off"
            or gkillState == "waiting"
            or time() - started >= STAND_STACK_GKILL_WAIT_TIMEOUT
        return
    end

    if cmd == "kill" then
        task.wait(FLING_DURATION + 0.25)
        return
    end

    if cmd == "loopkill" and STAND_COMMAND_IS_COMBAT(nextCmd) then
        task.wait(FLING_DURATION + 0.25)
        return
    end

    task.wait(STAND_STACK_COMMAND_DELAY)
end

function STAND_RUN_STACKED_CHAT(chunks, sender)
    task.spawn(function()
        for index, chunk in ipairs(chunks) do
            local cmd = STAND_GET_STACK_COMMAND(chunk)
            local nextCmd = chunks[index + 1] and STAND_GET_STACK_COMMAND(chunks[index + 1]) or nil
            onChat(chunk, sender, true)
            STAND_WAIT_AFTER_STACK_COMMAND(cmd, nextCmd)
        end
    end)
end

function STAND_GET_COMMAND_TARGET(argText)
    local target = getPlayer(argText)
    if target then return target end
    if not argText or tostring(argText):match("^%s*$") then
        return resolveSelectedTarget()
    end
    return nil
end

function onChat(message, sender, fromStack)
    message = tostring(message or "")
    if not isCommandSender(sender) then return end
    if message:sub(1, #PREFIX) ~= PREFIX then return end

    if not fromStack and STAND_SHOULD_IGNORE_MIRRORED_COMMAND(message, sender) then
        return
    end

    if not fromStack then
        local dedupeKey = tostring(sender.UserId or sender.Name) .. "|" .. message
        if STAND_LAST_CHAT_COMMAND_KEY == dedupeKey and time() - STAND_LAST_CHAT_COMMAND_TIME < 0.45 then
            return
        end
        STAND_LAST_CHAT_COMMAND_KEY = dedupeKey
        STAND_LAST_CHAT_COMMAND_TIME = time()
    end

    if not fromStack then
        local stackedCommands = STAND_SPLIT_STACKED_COMMANDS(message)
        if #stackedCommands > 1 then
            STAND_RUN_STACKED_CHAT(stackedCommands, sender)
            return
        end
    end


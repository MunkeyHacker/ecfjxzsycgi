function getUprightCFrame(position, lookAt)
    local flatLook = Vector3.new(lookAt.X, position.Y, lookAt.Z)
    if (flatLook - position).Magnitude < 0.1 then
        flatLook = position + Vector3.new(0, 0, -1)
    end
    return CFrame.new(position, flatLook)
end

function getTargetBodyGrabCFrame(target, attemptIndex)
    local char = getWorldCharacter(target)
    local bodyPart = getVisibleBodyPart(char)
    if not bodyPart then return nil end

    local root = getRoot(char)
    local startIndex = ((attemptIndex or 1) - 1) % #BODY_GRAB_OFFSETS
    local offset = BODY_GRAB_OFFSETS[startIndex + 1]
    local grabPos = bodyPart.CFrame:PointToWorldSpace(offset)
    for i = 1, #BODY_GRAB_OFFSETS do
        local tryOffset = BODY_GRAB_OFFSETS[((startIndex + i - 1) % #BODY_GRAB_OFFSETS) + 1]
        local tryPos = bodyPart.CFrame:PointToWorldSpace(tryOffset)
        if not STAND_IS_POSITION_CLEAR or STAND_IS_POSITION_CLEAR(tryPos, target, 2.4, 4.5) then
            grabPos = tryPos
            break
        end
    end

    local lookPos = root and root.Position or bodyPart.Position
    return getUprightCFrame(grabPos, lookPos)
end

function getTargetStompCFrame(target, attemptIndex)
    local char = getWorldCharacter(target)
    local bodyPart = getVisibleBodyPart(char)
    if not bodyPart then return nil end

    local angle = math.rad(((attemptIndex or 0) % 4) * 90)
    local sideOffset = Vector3.new(math.cos(angle) * STOMP_HOVER_RADIUS, 0, math.sin(angle) * STOMP_HOVER_RADIUS)
    local hoverPos = bodyPart.Position + Vector3.new(0, STOMP_HOVER_HEIGHT, 0) + sideOffset
    if STAND_IS_POSITION_CLEAR and not STAND_IS_POSITION_CLEAR(hoverPos, target, 2.2, 3.8) then
        hoverPos = bodyPart.Position + Vector3.new(0, STOMP_HOVER_HEIGHT + 0.9, 0)
    end
    return getUprightCFrame(hoverPos, bodyPart.Position)
end


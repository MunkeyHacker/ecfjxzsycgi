function STAND_FIND_FOOD_TOOL(nameList)
    for _, foodName in ipairs(nameList) do
        local tool = findInventoryTool(foodName)
        if tool and tool:IsA("Tool") then
            return tool
        end
    end

    local wanted = {}
    for _, foodName in ipairs(nameList) do
        wanted[tostring(foodName):gsub("[%[%]]", ""):lower()] = true
    end

    for _, container in ipairs(getInventoryContainers()) do
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local lowerName = tool.Name:gsub("[%[%]]", ""):lower()
                for foodName in pairs(wanted) do
                    if lowerName == foodName or lowerName:find(foodName, 1, true) then
                        return tool
                    end
                end
            end
        end
    end
    return nil
end

function STAND_IS_COOKIE_TOOL(tool)
    return tool and tool.Name:lower():find("cookie", 1, true) ~= nil
end

function STAND_FIND_ANY_FOOD_TOOL()
    local smallFood = STAND_FIND_FOOD_TOOL(STAND_SMALL_FOOD_NAMES)
    if smallFood then return smallFood end

    local cookie = STAND_FIND_FOOD_TOOL(STAND_COOKIE_FOOD_NAMES)
    if cookie then return cookie end

    for _, container in ipairs(getInventoryContainers()) do
        for _, tool in ipairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local lowerName = tool.Name:lower()
                for _, keyword in ipairs(STAND_FOOD_KEYWORDS) do
                    if lowerName:find(keyword, 1, true) then
                        return tool
                    end
                end
            end
        end
    end

    return nil
end

function STAND_CHOOSE_FOOD_TOOL(health)
    if not health then return nil end

    local cookie = STAND_FIND_FOOD_TOOL(STAND_COOKIE_FOOD_NAMES)
    local smallFood = STAND_FIND_FOOD_TOOL(STAND_SMALL_FOOD_NAMES)

    if health <= FOOD_EMERGENCY_COOKIE_THRESHOLD and cookie then
        return cookie
    end

    if health <= FOOD_COOKIE_HEAL_THRESHOLD and cookie and time() - lastCookieUse >= COOKIE_REUSE_COOLDOWN then
        return cookie
    end

    if health <= FOOD_SMALL_HEAL_THRESHOLD then
        return smallFood
    end

    return nil
end

function STAND_USE_FOOD_TOOL(tool)
    if foodBusy or not tool then return end
    foodBusy = true
    lastFoodUse = time()

    task.spawn(function()
        local character = LocalPlayer.Character
        local humanoid = getHumanoid(character)
        if not character or not humanoid or not tool.Parent then
            foodBusy = false
            return
        end

        local resumeGunName = gkillEnabled and currentGunName or nil

        pcall(function()
            if tool.Parent ~= character then
                humanoid:UnequipTools()
                task.wait(0.05)
                humanoid:EquipTool(tool)
            end
        end)

        task.wait(0.08)
        local clickCount = STAND_IS_COOKIE_TOOL(tool) and FOOD_COOKIE_CLICKS or FOOD_SMALL_CLICKS
        if STAND_IS_COOKIE_TOOL(tool) then
            lastCookieUse = time()
        end
        for _ = 1, clickCount do
            pcall(function()
                tool:Activate()
            end)
            task.wait(FOOD_CLICK_DELAY)
        end
        task.wait(0.12)

        if resumeGunName and gkillEnabled and gkillState == "attacking" then

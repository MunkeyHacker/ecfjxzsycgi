function updateErrorConsoleGui(force)
    if not force and time() - lastErrorConsoleUpdate < ERROR_CONSOLE_UPDATE_INTERVAL then return end
    lastErrorConsoleUpdate = time()

    createErrorConsoleGui()
    if not errorConsoleGui or not errorConsoleGui.Parent then return end
    errorConsoleGui.Enabled = STAND_ERROR_CONSOLE_VISIBLE

    if errorConsoleLabels.title then
        errorConsoleLabels.title.Text = "errors " .. tostring(#errorConsoleLog) .. "  !console"
    end

    local startIndex = math.max(1, #errorConsoleLog - ERROR_CONSOLE_MAX_LINES + 1)
    for lineIndex = 1, ERROR_CONSOLE_MAX_LINES do
        local label = errorConsoleLabels[lineIndex]
        if label then
            local item = errorConsoleLog[startIndex + lineIndex - 1]
            if item then
                label.Text = string.format("[%s] %s", item.kind, item.message)
                label.TextColor3 = item.kind == "ERR" and Color3.fromRGB(255, 115, 125) or Color3.fromRGB(255, 190, 120)
            else
                label.Text = ""
            end
        end
    end
end

function STAND_PUSH_ERROR_CONSOLE(kind, message)
    kind = tostring(kind or "ERR"):upper():sub(1, 4)
    message = tostring(message or ""):gsub("%s+", " "):match("^%s*(.-)%s*$") or ""
    if message == "" then return end

    local now = time()
    local key = kind .. "|" .. message
    if errorConsoleRecent[key] and now - errorConsoleRecent[key] < 0.6 then
        return
    end
    errorConsoleRecent[key] = now

    table.insert(errorConsoleLog, {
        kind = kind == "WARN" and "WARN" or "ERR",
        message = message,
        time = now,
    })

    while #errorConsoleLog > ERROR_CONSOLE_MAX_LOGS do
        table.remove(errorConsoleLog, 1)
    end

    updateErrorConsoleGui(true)
end


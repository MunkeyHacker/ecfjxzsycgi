function STAND_PARSE_KEYCODE(text)
    text = tostring(text or ""):match("^%s*(.-)%s*$") or ""
    if text == "" then return nil end
    local normalized = text:gsub("%s+", ""):lower()

    for _, keyCode in ipairs(Enum.KeyCode:GetEnumItems()) do
        if keyCode.Name:lower() == normalized then
            return keyCode
        end
    end

    if #normalized == 1 then
        local upperName = normalized:upper()
        for _, keyCode in ipairs(Enum.KeyCode:GetEnumItems()) do
            if keyCode.Name == upperName then
                return keyCode
            end
        end
    end

    return nil
end


startMainSafeSpotRescue = function(main, safeCFrame)
    if not main or not safeCFrame then return end
    if not shouldMainSafeSpotRescue(main) then
        pendingMainSafeSpotCFrame = nil
        mainRescueToken += 1
        return
    end

    if main == LocalPlayer then
        applyMainDeathSafeSpot(main, safeCFrame)
        return
    end

    mainRescueToken += 1
    local thisRescueToken = mainRescueToken
    local restoreFollow = true

    if gkillEnabled then
        stopGunKill(false)
    end

    stopSafeSpotSwitching()
    stopStrafing()
    isFollowing = false
    isFlying = false
    followTargetMoving = false
    releaseCharacterControl()

    local humanoid = getHumanoid(LocalPlayer.Character)
    if humanoid then
        pcall(function()
            humanoid:UnequipTools()
        end)
    end

    task.spawn(function()
        local started = time()
        local pickupAttempt = 0
        while thisRescueToken == mainRescueToken
            and main.Parent == Players
            and isTargetKO(main)
            and not hasGrabbingConstraint(main)
            and time() - started <= MAIN_RESCUE_PICKUP_TIME do

            local myRoot = getRoot(LocalPlayer.Character)
            local grabCFrame = getTargetBodyGrabCFrame(main, pickupAttempt)
            if myRoot and grabCFrame then
                setRootStableCFrame(myRoot, grabCFrame)
            end
            pickupAttempt += 1
            pressGrabKey()
            task.wait(GRAB_KEY_SPAM_INTERVAL)
        end

        if thisRescueToken ~= mainRescueToken then return end

        if hasGrabbingConstraint(main) then
            started = time()
            while thisRescueToken == mainRescueToken
                and hasGrabbingConstraint(main)
                and time() - started <= MAIN_RESCUE_DELIVER_TIMEOUT do

                local myRoot = getRoot(LocalPlayer.Character)
                if myRoot then
                    setRootStableCFrame(myRoot, safeCFrame)
                    if getXZDistanceSquared(myRoot.Position, safeCFrame.Position) <= (MAIN_RESCUE_SAFE_DISTANCE * MAIN_RESCUE_SAFE_DISTANCE) then
                        break
                    end
                end
                task.wait(0.05)
            end

            started = time()
            while thisRescueToken == mainRescueToken
                and hasGrabbingConstraint(main)
                and time() - started <= MAIN_RESCUE_DROP_TIMEOUT do

                local myRoot = getRoot(LocalPlayer.Character)
                if myRoot then
                    setRootStableCFrame(myRoot, safeCFrame)
                end
                pressGrabKey()
                task.wait(GRAB_KEY_SPAM_INTERVAL)
            end
        else
            local myRoot = getRoot(LocalPlayer.Character)
            if myRoot then
                setRootStableCFrame(myRoot, safeCFrame)
            end
        end

        if thisRescueToken ~= mainRescueToken then return end

        if restoreFollow then
            returnToMainFollow()
        end
    end)
end


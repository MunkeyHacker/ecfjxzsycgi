            if tostring(altName):lower() == LocalPlayer.Name:lower() then
                return math.clamp(index, 1, 2)
            end
        end
    end

    local slot = tonumber(STAND_ALT_SLOT) or 1
    return math.clamp(math.floor(slot), 1, 2)
end

function STAND_GET_BASE_FOLLOW_SIDE_SIGN()
    local side = tostring(STAND_ALT_SIDE or ""):lower()
    if side == "left" or side == "l" or side == "-1" then
        return -1
    end
    if side == "right" or side == "r" or side == "1" then
        return 1
    end
    return STAND_GET_ALT_SLOT() == 2 and -1 or 1
end

function STAND_GET_FOLLOW_SIDE_SIGN()
    return STAND_FOLLOW_SIDE_OVERRIDE_SIGN or STAND_GET_BASE_FOLLOW_SIDE_SIGN()
end

function STAND_GET_FOLLOW_SIDE_NAME()
    return STAND_GET_FOLLOW_SIDE_SIGN() < 0 and "LEFT" or "RIGHT"
end

function STAND_GET_ALT_SYNC_KEY(target)
    if target and target.UserId then
        return tostring(target.UserId)
    end
    return tostring(target and target.Name or ""):lower()
end

function STAND_RECORD_ACTIVE_ALT(altName, userId)
    altName = tostring(altName or "")
    if altName == "" then return end
    if altName == MAIN_USERNAME then return end
    if altName == STAND_COMMAND_OWNER_NAME then return end

    local altKey = altName:lower()
    local previous = STAND_ALT_ACTIVE[altKey]
    STAND_ALT_ACTIVE[altKey] = {
        name = altName,
        userId = tonumber(userId) or (previous and previous.userId) or 0,
        time = time(),
    }
end

function STAND_RECORD_ALT_ASSIGNMENT(targetKey, targetName, altName, sideSign)
    targetKey = tostring(targetKey or ""):lower()
    altName = tostring(altName or "")
    if targetKey == "" or altName == "" then return end

    STAND_ALT_ASSIGNMENTS[targetKey] = STAND_ALT_ASSIGNMENTS[targetKey] or {}
    STAND_ALT_ASSIGNMENTS[targetKey][altName:lower()] = {
        altName = altName,
        targetName = tostring(targetName or ""),
        sideSign = sideSign and sideSign < 0 and -1 or 1,
        time = time(),
    }
    STAND_RECORD_ACTIVE_ALT(altName, nil)
end

function STAND_CLEAN_ALT_ASSIGNMENTS()
    local now = time()
    for altKey, info in pairs(STAND_ALT_ACTIVE) do
        if not info or now - (info.time or 0) > STAND_ALT_SYNC_TTL then
            STAND_ALT_ACTIVE[altKey] = nil
        end
    end

    for targetKey, byAlt in pairs(STAND_ALT_ASSIGNMENTS) do
        for altKey, info in pairs(byAlt) do
            if not info or now - (info.time or 0) > STAND_ALT_SYNC_TTL then
                byAlt[altKey] = nil
            end
        end
        if next(byAlt) == nil then
            STAND_ALT_ASSIGNMENTS[targetKey] = nil
        end
    end
end

function STAND_GET_ALT_ORDER_RANK(altName)
    if type(STAND_ALT_ORDER) ~= "table" then return nil end
    for index, listedName in ipairs(STAND_ALT_ORDER) do
        if tostring(listedName):lower() == tostring(altName or ""):lower() then
            return index
        end
    end
    return nil
end

function STAND_GET_ACTIVE_ALT_LIST()
    STAND_RECORD_ACTIVE_ALT(LocalPlayer.Name, LocalPlayer.UserId)
    STAND_CLEAN_ALT_ASSIGNMENTS()

    local list = {}
    for _, info in pairs(STAND_ALT_ACTIVE) do
        if info and info.name and info.name ~= "" then
            table.insert(list, info)
        end
    end

    table.sort(list, function(a, b)
        local rankA = STAND_GET_ALT_ORDER_RANK(a.name)
        local rankB = STAND_GET_ALT_ORDER_RANK(b.name)
        if rankA and rankB and rankA ~= rankB then
            return rankA < rankB
        elseif rankA then
            return true
        elseif rankB then
            return false
        end

        local userA = tonumber(a.userId) or 0
        local userB = tonumber(b.userId) or 0
        if userA > 0 and userB > 0 and userA ~= userB then
            return userA < userB
        end
        return tostring(a.name):lower() < tostring(b.name):lower()
    end)

    return list
end

function STAND_GET_DETERMINISTIC_ALT_SIDE(target)
    local list = STAND_GET_ACTIVE_ALT_LIST()
    if #list < 2 then return nil end

    local baseSign = STAND_GET_BASE_FOLLOW_SIDE_SIGN()
    local myName = LocalPlayer.Name:lower()
    for index, info in ipairs(list) do
        if tostring(info.name or ""):lower() == myName then
            return index % 2 == 1 and baseSign or -baseSign
        end
    end
    return nil
end

function STAND_PLAYER_IS_ALT_CANDIDATE(plr, target)
    if not plr or plr == target then return false end
    if plr.Name == MAIN_USERNAME or plr.Name == tostring(STAND_COMMAND_OWNER_NAME or MAIN_USERNAME) then return false end
    if type(STAND_ALT_ORDER) == "table" and #STAND_ALT_ORDER > 0 then
        return STAND_GET_ALT_ORDER_RANK(plr.Name) ~= nil
    end
    return true
end

function STAND_GET_PLAYER_FOLLOW_ROOT(plr)
    if not plr then return nil end
    if plr == LocalPlayer then
        return getRoot(LocalPlayer.Character)
    end
    if type(getWorldCharacter) == "function" then
        return getRoot(getWorldCharacter(plr))
    end
    return getRoot(plr.Character)
end

function STAND_GET_PHYSICAL_FOLLOW_SIDE_SIGN(root, targetRoot)
    if not root or not targetRoot then return nil end
    local delta = root.Position - targetRoot.Position
    local sideOffset = delta:Dot(targetRoot.CFrame.RightVector)
    if math.abs(sideOffset) < FOLLOW_SIDE_OCCUPANCY_MIN_OFFSET then
        return nil
    end
    return sideOffset < 0 and -1 or 1
end

function STAND_GET_NEARBY_ALT_SIDE_OCCUPANCY(target, targetRoot)
    local hasRight = false
    local hasLeft = false

    if not targetRoot then return hasRight, hasLeft end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and STAND_PLAYER_IS_ALT_CANDIDATE(plr, target) then
            local root = STAND_GET_PLAYER_FOLLOW_ROOT(plr)
            if root then
                local delta = root.Position - targetRoot.Position
                local flatDistance = Vector3.new(delta.X, 0, delta.Z).Magnitude
                local heightOk = delta.Y >= 1.2 and delta.Y <= 10
                if heightOk and flatDistance <= FOLLOW_SIDE_COLLISION_RADIUS then
                    local sideSign = STAND_GET_PHYSICAL_FOLLOW_SIDE_SIGN(root, targetRoot)
                    if sideSign == 1 then
                        hasRight = true
                    elseif sideSign == -1 then
                        hasLeft = true
                    end
                end
            end
        end
    end

    return hasRight, hasLeft
end

function STAND_UPDATE_FOLLOW_SIDE_FROM_NEARBY(target, targetRoot)
    if not target or not targetRoot then return end
    local now = time()
    if now - lastFollowSideCollisionCheck < FOLLOW_SIDE_COLLISION_RECHECK_INTERVAL then return end
    lastFollowSideCollisionCheck = now

    local hasRight, hasLeft = STAND_GET_NEARBY_ALT_SIDE_OCCUPANCY(target, targetRoot)
    local myPhysicalSide = STAND_GET_PHYSICAL_FOLLOW_SIDE_SIGN(STAND_GET_PLAYER_FOLLOW_ROOT(LocalPlayer), targetRoot)
    if hasRight and not hasLeft then
        STAND_FOLLOW_SIDE_OVERRIDE_SIGN = myPhysicalSide == 1 and 1 or -1
        return
    elseif hasLeft and not hasRight then
        STAND_FOLLOW_SIDE_OVERRIDE_SIGN = myPhysicalSide == -1 and -1 or 1
        return
    end

    local contenders = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or STAND_PLAYER_IS_ALT_CANDIDATE(plr, target) then
            local root = STAND_GET_PLAYER_FOLLOW_ROOT(plr)
            if root then
                local delta = root.Position - targetRoot.Position
                local flatDistance = Vector3.new(delta.X, 0, delta.Z).Magnitude
                local heightOk = plr == LocalPlayer or (delta.Y >= 1.2 and delta.Y <= 10)
                if heightOk and flatDistance <= FOLLOW_SIDE_COLLISION_RADIUS then
                    table.insert(contenders, {
                        name = plr.Name,
                        userId = plr.UserId or 0,
                        player = plr,
                    })
                end
            end
        end
    end

    if #contenders < 2 then return end

    table.sort(contenders, function(a, b)
        local rankA = STAND_GET_ALT_ORDER_RANK(a.name)
        local rankB = STAND_GET_ALT_ORDER_RANK(b.name)
        if rankA and rankB and rankA ~= rankB then
            return rankA < rankB
        elseif rankA then
            return true
        elseif rankB then
            return false
        end

        local userA = tonumber(a.userId) or 0
        local userB = tonumber(b.userId) or 0
        if userA > 0 and userB > 0 and userA ~= userB then
            return userA < userB
        end
        return tostring(a.name):lower() < tostring(b.name):lower()
    end)

    local baseSign = STAND_GET_BASE_FOLLOW_SIDE_SIGN()
    local myName = LocalPlayer.Name:lower()
    for index, info in ipairs(contenders) do
        if tostring(info.name or ""):lower() == myName then
            STAND_FOLLOW_SIDE_OVERRIDE_SIGN = index % 2 == 1 and baseSign or -baseSign
            return
        end
    end
end

function STAND_PICK_FOLLOW_SIDE_FOR_TARGET(target)
    STAND_CLEAN_ALT_ASSIGNMENTS()

    local baseSign = STAND_GET_BASE_FOLLOW_SIDE_SIGN()
    local targetRoot = STAND_GET_PLAYER_FOLLOW_ROOT(target)
    if targetRoot then
        local hasRight, hasLeft = STAND_GET_NEARBY_ALT_SIDE_OCCUPANCY(target, targetRoot)
        if hasRight and not hasLeft then
            return -1
        elseif hasLeft and not hasRight then
            return 1
        end
    end

    local deterministicSign = STAND_GET_DETERMINISTIC_ALT_SIDE(target)
    if deterministicSign then
        return deterministicSign
    end

    local targetKey = STAND_GET_ALT_SYNC_KEY(target)
    local byAlt = STAND_ALT_ASSIGNMENTS[targetKey]
    if byAlt then
        for altKey, info in pairs(byAlt) do
            if altKey ~= LocalPlayer.Name:lower() and info.sideSign == baseSign then
                return -baseSign
            end
        end
    end

    return baseSign
end

function STAND_SEND_ALT_SYNC_MESSAGE(message)
    if not message or message == "" then return end
    -- Public chat sync is disabled; visible sync messages were too noisy.
end

function STAND_BUILD_ALT_SYNC_MESSAGE(target, sideSign)
    if not target then return nil end
    local targetKey = STAND_GET_ALT_SYNC_KEY(target)
    local sideText = sideSign and sideSign < 0 and "left" or "right"
    return table.concat({
        STAND_ALT_SYNC_PREFIX,
        "follow",
        LocalPlayer.Name,
        targetKey,
        target.Name,
        sideText,
    }, "|")
end

function STAND_BROADCAST_ALT_HELLO(force)
    local now = time()
    if not force and now - STAND_ALT_LAST_SYNC < STAND_ALT_HELLO_INTERVAL then return end
    STAND_ALT_LAST_SYNC = now
    STAND_RECORD_ACTIVE_ALT(LocalPlayer.Name, LocalPlayer.UserId)
end

function STAND_BROADCAST_ALT_ASSIGNMENT(target, sideSign)
    if not target then return end
    local message = STAND_BUILD_ALT_SYNC_MESSAGE(target, sideSign)
    STAND_RECORD_ALT_ASSIGNMENT(STAND_GET_ALT_SYNC_KEY(target), target.Name, LocalPlayer.Name, sideSign)
    STAND_SEND_ALT_SYNC_MESSAGE(message)
end

function STAND_ASSIGN_FOLLOW_SIDE(target)
    STAND_BROADCAST_ALT_HELLO(true)
    local sideSign = STAND_PICK_FOLLOW_SIDE_FOR_TARGET(target)
    STAND_FOLLOW_SIDE_OVERRIDE_SIGN = sideSign
    STAND_BROADCAST_ALT_ASSIGNMENT(target, sideSign)
    return sideSign
end

function STAND_HANDLE_ALT_SYNC_MESSAGE(message, sender)
    local text = tostring(message or "")
    if text:sub(1, #STAND_ALT_SYNC_PREFIX) ~= STAND_ALT_SYNC_PREFIX then
        return false
    end

    local parts = {}
    for part in text:gmatch("[^|]+") do
        table.insert(parts, part)
    end

    if parts[1] ~= STAND_ALT_SYNC_PREFIX then
        return true
    end

    if parts[2] == "hello" then
        STAND_RECORD_ACTIVE_ALT(parts[3] or (sender and sender.Name) or "", parts[4])
    elseif parts[2] == "follow" then
        local altName = parts[3] or (sender and sender.Name) or ""
        local targetKey = parts[4] or ""
        local targetName = parts[5] or ""
        local sideText = tostring(parts[6] or ""):lower()
        local sideSign = (sideText == "left" or sideText == "-1") and -1 or 1
        STAND_RECORD_ALT_ASSIGNMENT(targetKey, targetName, altName, sideSign)
    end
    return true
end


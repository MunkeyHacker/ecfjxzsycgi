local pendingMainSafeSpotCFrame = nil
local startMainSafeSpotRescue

function shouldMainSafeSpotRescue(main)
    return isFollowing
        and main ~= nil
        and (followTarget == main or followTargetName == main.Name or followTargetName == STAND_GET_COMMAND_OWNER_NAME())
end

function getXZDistanceSquared(a, b)
    local dx = a.X - b.X
    local dz = a.Z - b.Z
    return (dx * dx) + (dz * dz)
end

function getClosestMainSafeSpot(position)
    if not position then return MAIN_DEATH_SAFE_SPOTS[1] end

    local closest = MAIN_DEATH_SAFE_SPOTS[1]
    local closestDistance = math.huge
    for _, safeSpot in ipairs(MAIN_DEATH_SAFE_SPOTS) do
        local distance = getXZDistanceSquared(position, safeSpot.Position)
        if distance < closestDistance then
            closestDistance = distance
            closest = safeSpot
        end
    end
    return closest
end

function moveCharacterToCFrame(char, cframe)
    local root = getRoot(char)
    if not root or not cframe then return false end

    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    root.CFrame = cframe
    return true
end

function applyMainDeathSafeSpot(main, cframe)
    if not main or not cframe then return false end
    return moveCharacterToCFrame(main.Character, cframe)
end

function bindMainDeathCharacter(main, char)
    mainDeathConnection = disconnect(mainDeathConnection)
    mainKOConnection = disconnect(mainKOConnection)
    local humanoid = getHumanoid(char)
    if not humanoid then return end

    local function queueMainRescue()
        if not shouldMainSafeSpotRescue(main) then
            pendingMainSafeSpotCFrame = nil
            mainRescueToken += 1
            return
        end

        local positionChar = main.Character or char
        local root = getRoot(positionChar)
        local ok, pivot = pcall(function()
            return positionChar:GetPivot()
        end)
        local mainPosition = root and root.Position or (ok and pivot.Position or nil)
        pendingMainSafeSpotCFrame = getClosestMainSafeSpot(mainPosition)
        if startMainSafeSpotRescue then
            startMainSafeSpotRescue(main, pendingMainSafeSpotCFrame)
        end
    end

    local bodyEffects = char:FindFirstChild("BodyEffects")
    local koBool = bodyEffects and (bodyEffects:FindFirstChild("K.O") or bodyEffects:FindFirstChild("KO"))
    if koBool then
        mainKOConnection = track(koBool:GetPropertyChangedSignal("Value"):Connect(function()
            if koBool.Value == true then
                queueMainRescue()
            end
        end))
        if koBool.Value == true then
            task.defer(queueMainRescue)
        end
    end

    mainDeathConnection = track(humanoid.Died:Connect(function()
        if not shouldMainSafeSpotRescue(main) then
            pendingMainSafeSpotCFrame = nil
            mainRescueToken += 1
            return
        end

        local positionChar = main.Character or char
        local root = getRoot(positionChar)
        local ok, pivot = pcall(function()
            return positionChar:GetPivot()
        end)
        local deathPosition = root and root.Position or (ok and pivot.Position or nil)
        pendingMainSafeSpotCFrame = getClosestMainSafeSpot(deathPosition)
    end))
end

function watchMainDeathSafespot()
    mainDeathConnection = disconnect(mainDeathConnection)
    mainKOConnection = disconnect(mainKOConnection)
    mainCharacterConnection = disconnect(mainCharacterConnection)

    local main = getMainPlayer()
    if not main then return end

    if main.Character then
        bindMainDeathCharacter(main, main.Character)
    end

    mainCharacterConnection = track(main.CharacterAdded:Connect(function(char)
        task.wait(1.2)
        bindMainDeathCharacter(main, char)
        if pendingMainSafeSpotCFrame and shouldMainSafeSpotRescue(main) then
            local safeCFrame = pendingMainSafeSpotCFrame
            pendingMainSafeSpotCFrame = nil
            task.spawn(function()
                local started = time()
                repeat
                    applyMainDeathSafeSpot(main, safeCFrame)
                    task.wait(0.1)
                    local mainRoot = getRoot(main.Character)
                    if mainRoot and getXZDistanceSquared(mainRoot.Position, safeCFrame.Position) <= 64 then
                        break
                    end
                until time() - started > 2
            end)
        else
            pendingMainSafeSpotCFrame = nil
        end
    end))
end


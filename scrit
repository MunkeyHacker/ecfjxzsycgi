                return
            end
            STAND_ENABLE_MOUSE_AIM_HOOK = true
            installGKillMouseAimHook()
            print("Aim hook -> ON request sent")
        elseif arg == "off" or arg == "false" or arg == "0" then
            STAND_ENABLE_MOUSE_AIM_HOOK = false
            clearGKillMouseAim()
            print("Aim hook -> OFF for this script. Restart Roblox/executor to remove an older installed hook.")
        else
            print("Aim hook -> " .. (STAND_ENABLE_MOUSE_AIM_HOOK and "ON" or "OFF"))
        end

    elseif cmd == "moveassist" then
        local arg = tostring(argText or ""):match("^%s*(.-)%s*$"):lower()
        if arg == "on" or arg == "true" or arg == "1" then
            STAND_MOVEMENT_ASSIST.Active = true
        elseif arg == "off" or arg == "false" or arg == "0" then
            STAND_MOVEMENT_ASSIST.Active = false
            if movementAssistOverlay then
                movementAssistOverlay.Visible = false
            end
        elseif arg == "overlay" or arg == "show" then
            STAND_MOVEMENT_ASSIST.VisualAssist.ShowOverlay = not STAND_MOVEMENT_ASSIST.VisualAssist.ShowOverlay
        end
        print("MoveAssist -> " .. (STAND_MOVEMENT_ASSIST.Active and "ON" or "OFF")
            .. " overlay " .. (STAND_MOVEMENT_ASSIST.VisualAssist.ShowOverlay and "ON" or "OFF"))

    elseif cmd == "profile" then
        local arg = tostring(argText or ""):match("^%s*(.-)%s*$"):lower()
        if arg == "mobile" or arg == "m" then
            STAND_SET_DEVICE_PROFILE("mobile")
        elseif arg == "desktop" or arg == "pc" or arg == "laptop" or arg == "d" then
            STAND_SET_DEVICE_PROFILE("desktop")
        else
            print("Profile -> " .. STAND_DEVICE_PROFILE .. " (touchOnly=" .. tostring(STAND_TOUCH_ONLY_DEVICE) .. ")")
        end

    elseif cmd == "focus" then
        STAND_TRY_MOBILE_FOCUS(true)
    end
end


-- ====================== MAIN LOOP ======================
track(RunService.Heartbeat:Connect(function()
    STAND_BROADCAST_ALT_HELLO(false)

    if time() - STAND_LAST_CHAT_RESTORE >= STAND_CHAT_RESTORE_INTERVAL then
        STAND_LAST_CHAT_RESTORE = time()
        STAND_RESTORE_CHAT_VISIBILITY()
    end

    if isFollowing and (not followTarget or followTarget.Parent ~= Players) and followTargetName then
        followTarget = Players:FindFirstChild(followTargetName)
    end

    -- Normal follow resumes whenever gun strafing is inactive.
    if isFollowing and followTarget and LocalPlayer.Character and not gkillEnabled and not activelyStrafing and not safeSpotConnection and time() >= reloadUntil then
        local myRoot = getRoot(LocalPlayer.Character)
        local tRoot = getRoot(getWorldCharacter(followTarget))
        if myRoot and tRoot then
            local flatVelocity = Vector3.new(tRoot.AssemblyLinearVelocity.X, 0, tRoot.AssemblyLinearVelocity.Z)
            local targetKO = isTargetKO(followTarget)
            if targetKO then
                flatVelocity = Vector3.zero
            end
            followTargetMoving = not targetKO and flatVelocity.Magnitude > FOLLOW_MOVE_THRESHOLD

            STAND_UPDATE_FOLLOW_SIDE_FROM_NEARBY(followTarget, tRoot)
            local sideDistance = FOLLOW_SIDE_DISTANCE * STAND_GET_FOLLOW_SIDE_SIGN()
            local backOffset = followTargetMoving and FOLLOW_MOVE_BACK_OFFSET or FOLLOW_IDLE_BACK_OFFSET
            local height = followTargetMoving and FOLLOW_MOVE_HEIGHT or FOLLOW_IDLE_HEIGHT
            if not followTargetMoving then
                height += math.sin(time() * FOLLOW_IDLE_BOB_SPEED) * FOLLOW_IDLE_BOB_AMOUNT
            end
            local predictedMainPos = tRoot.Position + (flatVelocity * FOLLOW_POSITION_LEAD)
            local targetPos = predictedMainPos
                + (tRoot.CFrame.RightVector * sideDistance)
                - (tRoot.CFrame.LookVector * backOffset)
                + Vector3.new(0, height, 0)
            local targetLook = targetPos + tRoot.CFrame.LookVector

            myRoot.AssemblyLinearVelocity = followTargetMoving and tRoot.AssemblyLinearVelocity or Vector3.zero
            myRoot.AssemblyAngularVelocity = Vector3.zero
            myRoot.CFrame = CFrame.new(targetPos, targetLook)
            if myRoot.Position.Y < -200 then
                myRoot.CFrame += Vector3.new(0, 300, 0)
            end
        end
    elseif not isFollowing then
        followTargetMoving = false
    end

    if loopkillEnabled and (not loopkillTarget or loopkillTarget.Parent ~= Players) and loopkillTargetName then
        loopkillTarget = Players:FindFirstChild(loopkillTargetName)
    end

    -- Loop fling.
    if loopkillEnabled and loopkillTarget and loopkillTarget.Character and isAlive(loopkillTarget) and time() - lastLoopFling >= LOOPKILL_INTERVAL then
        if fling(loopkillTarget) then
            lastLoopFling = time()
        end
    end

    STAND_UPDATE_ANNOY()

    if AUTO_EAT_FOOD and time() - lastFoodCheck >= FOOD_CHECK_INTERVAL then
        lastFoodCheck = time()
        STAND_TRY_USE_FOOD()
    end

    if AUTO_BUY_ARMOR and time() - lastArmorCheck >= ARMOR_CHECK_INTERVAL then
        lastArmorCheck = time()
        local armor = getArmorValue()
        local health = getHealthValue()
        if armor ~= nil and armor < ARMOR_FULL_VALUE
            and health and health > 0
            and time() - lastArmorBuy >= ARMOR_BUY_COOLDOWN
            and not armorBusy
            and not gkillEnabled
            and gkillState ~= "reloading"
            and not flingBusy
            and not loopkillEnabled then
            buyFullArmor()
        end
    end

    if time() - lastStatusUpdate >= STATUS_UPDATE_INTERVAL then
        lastStatusUpdate = time()
        updateMainESP()
        updateTargetESP()
        updateTargetView()
        updateStatusGui()
    end
end))


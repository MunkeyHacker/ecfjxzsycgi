function clearGKillMouseAim()
    STAND_GKILL_MOUSE_AIM_STATE.active = false
    STAND_GKILL_MOUSE_AIM_STATE.position = nil
    STAND_GKILL_MOUSE_AIM_STATE.targetPart = nil

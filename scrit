function isShotBlocked(fromPosition, aimPosition, target)
    if not WALLCHECK_ENABLED or not fromPosition or not aimPosition then return false end

    local direction = aimPosition - fromPosition
    if direction.Magnitude < 1 then return false end

    STAND_RAYCAST_PARAMS.FilterDescendantsInstances = {
        LocalPlayer.Character,
        getWorldCharacter(target),
    }

    if Workspace:Raycast(fromPosition, direction, STAND_RAYCAST_PARAMS) == nil then
        return false
    end

    local right = direction:Cross(Vector3.yAxis)
    if right.Magnitude < 0.05 then
        right = Vector3.xAxis
    else
        right = right.Unit
    end

    local up = Vector3.yAxis
    local offsets = {
        right * 0.85,
        right * -0.85,
        up * 0.9,
        (right * 0.55) + (up * 0.45),
        (right * -0.55) + (up * 0.45),
    }

    for _, offset in ipairs(offsets) do
        local adjustedAim = aimPosition + offset
        local adjustedDirection = adjustedAim - fromPosition
        if adjustedDirection.Magnitude >= 1
            and Workspace:Raycast(fromPosition, adjustedDirection, STAND_RAYCAST_PARAMS) == nil then
            return false
        end
    end

    return true
end

STAND_IS_POSITION_CLEAR = function(position, target, radius, height)
    if not position then return false end

    local ok, parts = pcall(function()
        STAND_OVERLAP_PARAMS.FilterDescendantsInstances = {
            LocalPlayer.Character,
            getWorldCharacter(target),
        }

        local boxSize = Vector3.new(radius or 3.25, height or 5.5, radius or 3.25)
        return Workspace:GetPartBoundsInBox(CFrame.new(position), boxSize, STAND_OVERLAP_PARAMS)
    end)

    if not ok or not parts then
        return true
    end

    for _, part in ipairs(parts) do
        if part:IsA("BasePart")
            and part.CanCollide
            and part.Transparency < 0.96
            and not part.Name:lower():find("hitbox", 1, true) then
            return false
        end
    end

    return true
end

function getClearCloseGunPosition(targetRoot, aimPos, target, fallbackPosition, attemptIndex, forceSide)
    if not targetRoot or not aimPos then return fallbackPosition end

    local baseAngles = forceSide
        and { 0, 180, 25, -25, 155, -155, 90, -90 }
        or { 0, 45, -45, 90, -90, 135, -135, 180 }
    local baseOffset = attemptIndex or 0
    local closeRadius = forceSide and GRABBED_GKILL_SIDE_RADIUS or WALLCHECK_CLOSE_RADIUS
    local closeHeight = forceSide and GRABBED_GKILL_SIDE_HEIGHT or WALLCHECK_CLOSE_HEIGHT
    local bestCandidate = nil
    local bestScore = -math.huge
    for i = 1, #baseAngles do
        local angle = math.rad(baseAngles[((i + baseOffset - 1) % #baseAngles) + 1])
        local direction = (targetRoot.CFrame.RightVector * math.cos(angle)) + (targetRoot.CFrame.LookVector * math.sin(angle))
        if direction.Magnitude < 0.1 then
            direction = Vector3.new(math.cos(angle), 0, math.sin(angle))
        end

        local candidate = targetRoot.Position + (direction.Unit * closeRadius) + Vector3.new(0, closeHeight, 0)
        if not isShotBlocked(candidate, aimPos, target) and STAND_IS_POSITION_CLEAR(candidate, target) then
            local distanceScore = -math.abs((candidate - targetRoot.Position).Magnitude - closeRadius)
            local sideScore = math.abs(direction.Unit:Dot(targetRoot.CFrame.RightVector)) * 1.8
            local heightScore = -math.abs((candidate.Y - targetRoot.Position.Y) - closeHeight) * 0.2
            local fallbackScore = fallbackPosition and -((candidate - fallbackPosition).Magnitude * 0.035) or 0
            local score = distanceScore + sideScore + heightScore + fallbackScore
            if score > bestScore then
                bestScore = score
                bestCandidate = candidate
            end
        end
    end
    if bestCandidate then
        return bestCandidate
    end

    local towardCurrent = fallbackPosition - targetRoot.Position
    local flatDirection = Vector3.new(towardCurrent.X, 0, towardCurrent.Z)
    if flatDirection.Magnitude < 0.1 then
        flatDirection = targetRoot.CFrame.LookVector
    end

    local fallback = targetRoot.Position + (flatDirection.Unit * closeRadius) + Vector3.new(0, closeHeight, 0)
    return STAND_IS_POSITION_CLEAR(fallback, target) and fallback or fallbackPosition
end

function startStrafing(target)
    stopStrafing()
    activelyStrafing = true
    local nextSwitch = 0
    local nextWallCheck = 0
    local closeAttempt = 0
    local wallBlocked = false
    local offset = Vector3.new(STRAFE_RADIUS, STRAFE_HEIGHT, 0)
    local smoothedPosition = nil
    local sideSign = 1

    strafeConnection = track(RunService.Heartbeat:Connect(function()
        if not gkillEnabled or gkillState ~= "attacking" then
            stopStrafing()
            return
        end

        local tRoot = getRoot(getWorldCharacter(target))
        local myRoot = getRoot(LocalPlayer.Character)
        if not tRoot or not myRoot or not isAlive(target) then
            stopStrafing()
            return
        end

        local now = time()
        local targetGrabbed = hasGrabbingConstraint(target)
        if now >= nextSwitch then
            if targetGrabbed then
                sideSign = -sideSign
                local side = tRoot.CFrame.RightVector * (GRABBED_GKILL_SIDE_RADIUS * sideSign)
                local forward = tRoot.CFrame.LookVector * math.random(-2, 2)
                offset = side + forward + Vector3.new(0, math.random(2, 4), 0)
            else
                local x = math.random(-STRAFE_RADIUS, STRAFE_RADIUS)
                local z = math.random(-STRAFE_RADIUS, STRAFE_RADIUS)
                if math.abs(x) < 4 then x = x < 0 and -4 or 4 end
                if math.abs(z) < 4 then z = z < 0 and -4 or 4 end
                offset = Vector3.new(x, math.random(STRAFE_HEIGHT - 1, STRAFE_HEIGHT + 3), z)
            end
            nextSwitch = now + STRAFE_SWITCH_INTERVAL
        end

        local aimPos, aimPart = getAimPosition(target)
        aimPos = aimPos or (tRoot.Position + Vector3.new(0, 1.8, 0))
        local targetVelocity = tRoot.AssemblyLinearVelocity
        local targetFlatSpeed = Vector3.new(targetVelocity.X, 0, targetVelocity.Z).Magnitude
        local targetLead = math.clamp(STRAFE_TARGET_LEAD + (targetFlatSpeed / 700), STRAFE_TARGET_LEAD, 0.32)
        local predictedTargetPosition = tRoot.Position + Vector3.new(targetVelocity.X, math.clamp(targetVelocity.Y, -45, 45), targetVelocity.Z) * targetLead
        local targetPos = predictedTargetPosition + offset
        if WALLCHECK_ENABLED and now >= nextWallCheck then
            wallBlocked = isShotBlocked(targetPos, aimPos, target)
            nextWallCheck = now + WALLCHECK_RECHECK_INTERVAL
            if wallBlocked then
                closeAttempt += 1
            end
        end
        if not STAND_IS_POSITION_CLEAR(targetPos, target) then
            wallBlocked = true
            closeAttempt += 1
        end
        if wallBlocked then
            targetPos = getClearCloseGunPosition(tRoot, aimPos, target, targetPos, closeAttempt, targetGrabbed)
        else
            closeAttempt = math.max(closeAttempt - 1, 0)
        end

        smoothedPosition = smoothedPosition and smoothedPosition:Lerp(targetPos, STRAFE_LERP_ALPHA) or targetPos
        myRoot.AssemblyLinearVelocity = Vector3.zero
        myRoot.CFrame = CFrame.new(smoothedPosition, aimPos)
        aimAtTarget(target, aimPos, aimPart)
    end))
end


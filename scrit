function attachChatListener(plr)
    track(plr.Chatted:Connect(function(msg)
        onChat(msg, plr)
    end))
end

function attachAltSyncListener(plr)
    track(plr.Chatted:Connect(function(msg)
        STAND_HANDLE_ALT_SYNC_MESSAGE(msg, plr)
    end))
end

function attachTextChatServiceListener()
    pcall(function()
        local textChatService = game:GetService("TextChatService")
        if not textChatService or not textChatService.MessageReceived then return end

        track(textChatService.MessageReceived:Connect(function(chatMessage)
            local source = chatMessage and chatMessage.TextSource
            local sender = source and Players:GetPlayerByUserId(source.UserId)
            if sender then
                local text = chatMessage.Text or ""
                if STAND_HANDLE_ALT_SYNC_MESSAGE(text, sender) then
                    return
                end
                onChat(text, sender)
            end
        end))
    end)
end

function attachErrorConsoleListeners()
    track(LogService.MessageOut:Connect(function(message, messageType)
        local messageTypeText = tostring(messageType)
        if messageTypeText:find("Error", 1, true) then
            STAND_PUSH_ERROR_CONSOLE("ERR", message)
        elseif messageTypeText:find("Warning", 1, true) then
            STAND_PUSH_ERROR_CONSOLE("WARN", message)
        end
    end))

    pcall(function()
        track(ScriptContext.Error:Connect(function(message, stackTrace)
            local combined = tostring(message or "")
            if stackTrace and tostring(stackTrace) ~= "" then
                combined = combined .. " | " .. tostring(stackTrace)
            end
            STAND_PUSH_ERROR_CONSOLE("ERR", combined)
        end))
    end)
end


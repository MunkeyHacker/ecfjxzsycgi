        stopGunKill(false)
        if autoStompEnabled and not customBringDelivery then
            task.defer(function()
                startPostDropStomp(target, reloadGunName, returnCFrame, restoreFollow)
            end)
        elseif reloadInventorySafely then
            task.defer(function()
                reloadInventorySafely(reloadGunName, returnCFrame, function()
                    if restoreFollow
                        and resumeFollowToken == followResumeToken
                        and not gkillEnabled
                        and not loopkillEnabled then
                        returnToMainFollow()
                    end
                end)
            end)
        elseif restoreFollow
            and resumeFollowToken == followResumeToken
            and not gkillEnabled
            and not loopkillEnabled then
            returnToMainFollow()
        end
    end
end

function startKOCarry(target)
    if not gkillEnabled or not target or currentGTarget ~= target or gkillState == "carrying" then return end
    if not STAND_LOCAL_ALIVE() then return end

    grabTaskToken += 1
    local thisGrabToken = grabTaskToken
    gkillState = "carrying"
    clearGKillMouseAim()
    stopStrafing()
    currentGun = nil

    STAND_UNEQUIP_TOOLS()

    task.spawn(function()
        local started = time()
        local pickupAttempt = 0
        while thisGrabToken == grabTaskToken
            and gkillEnabled
            and STAND_LOCAL_ALIVE()
            and currentGTarget == target
            and isTargetKO(target)
            and not hasGrabbingConstraint(target)
            and time() - started <= KO_PICKUP_RETRY_TIME do

            STAND_UNEQUIP_TOOLS()
            local myRoot = getRoot(LocalPlayer.Character)
            local grabCFrame = getTargetBodyGrabCFrame(target, pickupAttempt)
            if myRoot and grabCFrame then
                setRootStableCFrame(myRoot, grabCFrame)
            end
            pickupAttempt += 1
            pressGrabKey()
            task.wait(GRAB_KEY_SPAM_INTERVAL)
        end

        if thisGrabToken ~= grabTaskToken or not gkillEnabled or currentGTarget ~= target then return end

        if not hasGrabbingConstraint(target) then
            resumeAttackAfterGrabRetry(target)
            return
        end

        local delivered = false
        started = time()
        while thisGrabToken == grabTaskToken
            and gkillEnabled
            and STAND_LOCAL_ALIVE()
            and currentGTarget == target
            and hasGrabbingConstraint(target)
            and time() - started <= KO_DELIVER_TIMEOUT do

            local myRoot = getRoot(LocalPlayer.Character)
            local deliveryCFrame, deliveryPosition = getKODeliveryCFrame(target)
            STAND_UNEQUIP_TOOLS()
            if deliveryCFrame and deliveryPosition and myRoot then
                setRootStableCFrame(myRoot, deliveryCFrame)
                if (myRoot.Position - deliveryPosition).Magnitude <= MAIN_DELIVERY_ARRIVE_DISTANCE then
                    delivered = true
                    break
                end
            end
            task.wait(0.05)
        end

        if thisGrabToken ~= grabTaskToken or not gkillEnabled or currentGTarget ~= target then return end

        local mainWaitStarted = time()
        while not delivered and time() - mainWaitStarted <= 1.5 do
            local myRoot = getRoot(LocalPlayer.Character)
            local _, deliveryPosition = getKODeliveryCFrame(target)
            if deliveryPosition and myRoot and (myRoot.Position - deliveryPosition).Magnitude <= MAIN_DELIVERY_ARRIVE_DISTANCE then
                delivered = true
                break
            end
            task.wait(0.05)
        end

        started = time()
        while thisGrabToken == grabTaskToken
            and gkillEnabled
            and STAND_LOCAL_ALIVE()
            and currentGTarget == target
            and hasGrabbingConstraint(target)
            and time() - started <= KO_DROP_TIMEOUT do

            local myRoot = getRoot(LocalPlayer.Character)
            local deliveryCFrame = getKODeliveryCFrame(target)
            STAND_UNEQUIP_TOOLS()
            if deliveryCFrame and myRoot then
                setRootStableCFrame(myRoot, deliveryCFrame)
            end
            pressGrabKey()
            task.wait(GRAB_KEY_SPAM_INTERVAL)
        end

        finishKOCarry(target, thisGrabToken)
    end)
end

function STAND_FINISH_GUNKILL_WITH_FLING(target)
    target = target or currentGTarget
    if not gkillEnabled or not target or currentGTarget ~= target then return end
    if gkillState == "flinging" then return end

    local loopMode = gloopkillEnabled
    local restoreFollow = wasFollowingMainBeforeGun or isFollowing
    local resumeFollowToken = followResumeToken
    local thisGunSession = gunSessionToken

    grabTaskToken += 1
    stopStrafing()
    stopSafeSpotSwitching()
    STAND_UNEQUIP_TOOLS()
    gkillState = "flinging"
    clearGKillMouseAim()

    if loopMode then
        fling(target)
        task.delay(FLING_DURATION + 0.25, function()
            if thisGunSession ~= gunSessionToken or not gkillEnabled or currentGTarget ~= target then return end
            if target.Parent == Players and isAlive(target) and not isTargetKO(target) then
                gkillState = "attacking"
                lastEquipAttempt = 0
                equipAnyGun(currentGunName)
                startStrafing(target)
            elseif gloopkillEnabled then
                gkillState = "waiting"
                goSafeSpot()
            else
                stopGunKill(false)
            end
        end)
        return
    end

    wasFollowingMainBeforeGun = false
    if restoreFollow then
        clearFollow()
        resumeFollowToken = followResumeToken
    end

    stopGunKill(false)

    if fling(target) then
        task.delay(FLING_DURATION + 0.25, function()
            if restoreFollow and resumeFollowToken == followResumeToken and not loopkillEnabled and not gkillEnabled then
                returnToMainFollow()
            end
        end)
    elseif restoreFollow and resumeFollowToken == followResumeToken then
        returnToMainFollow()
    end
end

function handleTargetKO(target)
    target = target or currentGTarget
    if not gkillEnabled or not target or currentGTarget ~= target then return end
    if gkillState == "waiting" or gkillState == "reloading" or gkillState == "carrying" or gkillState == "flinging" then return end
    if not isTargetKO(target) then return end

    if STAND_GKILL_MODE == STAND_GKILL_MODE_FLING then
        STAND_FINISH_GUNKILL_WITH_FLING(target)
    else
        startKOCarry(target)
    end
end

function handleTargetDown()
    if not gkillEnabled or gkillState == "waiting" or gkillState == "flinging" then return end

    grabTaskToken += 1
    stopStrafing()

    if STAND_GKILL_MODE == STAND_GKILL_MODE_FLING then
        STAND_FINISH_GUNKILL_WITH_FLING(currentGTarget)
        return
    end

    if gloopkillEnabled then
        gkillState = "waiting"
        goSafeSpot()
        return
    end

    stopGunKill(false)
end

function watchTarget(target)
    cleanupGunTargetConnections()

    local humanoid = getHumanoid(target and target.Character)
    if humanoid then
        deathConnection = track(humanoid.Died:Connect(handleTargetDown))
    end

    local koBool = getKOBool(target)
    if koBool then
        koConnection = track(koBool:GetPropertyChangedSignal("Value"):Connect(function()
            if isTargetKO(target) then
                handleTargetKO(target)
            end
        end))
    end

    if target then
        charAddedConnection = track(target.CharacterAdded:Connect(function(char)
            if not gloopkillEnabled then return end
            task.wait(1)
            if currentGTarget == target and gkillEnabled then
                local newHumanoid = getHumanoid(char)
                deathConnection = disconnect(deathConnection)
                if newHumanoid then
                    deathConnection = track(newHumanoid.Died:Connect(handleTargetDown))
                end
                koConnection = disconnect(koConnection)
                local newKOBool = getKOBool(target)
                if newKOBool then
                    koConnection = track(newKOBool:GetPropertyChangedSignal("Value"):Connect(function()
                        if isTargetKO(target) then
                            handleTargetKO(target)
                        end
                    end))
                end
                if gkillState == "flinging" then
                    return
                end
                if gloopkillEnabled and isAlive(target) and not isTargetKO(target) then
                    gkillState = "attacking"
                    lastEquipAttempt = 0
                    equipAnyGun(currentGunName)
                    stopSafeSpotSwitching()
                    startStrafing(target)
                end
            end
        end))
    end

    if isTargetKO(target) then
        task.defer(function()
            handleTargetKO(target)
        end)
    end
end

hardReloadGun = nil

function switchFromEmptyGun(tool)
    if not tool or toolHasAmmo(tool) then
        return tool
    end

    local now = time()
    if now - lastAmmoSwitchAttempt < EQUIP_RETRY_INTERVAL then
        return nil
    end
    lastAmmoSwitchAttempt = now
    lastEquipAttempt = 0

    local nextTool = equipAnyGun(nil, true, tool.Name)
    if nextTool then
        print("Ammo empty on " .. tool.Name .. " -> switched to " .. nextTool.Name)
        return nextTool
    end

    if AUTO_RELOAD_WHEN_ALL_GUNS_EMPTY and hardReloadGun then
        print("All guns empty -> switching guns and pressing R until ammo refills")
        hardReloadGun(tool.Name)
    else
        print("All guns empty -> auto reload disabled")
    end

    return nil
end

function fireEquippedTool(target, aimPos, aimPart)
    if not STAND_LOCAL_ALIVE() then return end
    if time() < reloadUntil then return end
    local now = time()
    if now - lastGunFire < GUN_FIRE_INTERVAL then return end
    lastGunFire = now

    local tool = getEquippedTool()
    if not isGunTool(tool) or (currentGunName and tool.Name ~= currentGunName) then
        tool = equipAnyGun(currentGunName)
    end

    if tool and not toolHasAmmo(tool) then
        tool = switchFromEmptyGun(tool)
        if not tool then
            return
        end
    end

    if tool then
        currentGun = tool
        currentGunName = tool.Name
        if aimPos then
            STAND_GKILL_MOUSE_AIM_STATE.active = gkillEnabled and gkillState == "attacking"
            STAND_GKILL_MOUSE_AIM_STATE.position = aimPos
            STAND_GKILL_MOUSE_AIM_STATE.targetPart = aimPart
        else
            aimAtTarget(target)
        end
        pcall(function() tool:Activate() end)
        clearGKillMouseAim()
        STAND_MOBILE_VIRTUAL_FIRE()
    end
end

function STAND_VALUE_DROPPED(beforeValue, currentValue)
    return beforeValue and currentValue and currentValue < beforeValue - STAND_ANNOY_CONFIG.damageEpsilon
end

function STAND_ANNOY_KNIFE_ONCE(target)
    local beforeValue = STAND_GET_TARGET_COMBINED_VALUE(target)
    local tool = STAND_EQUIP_TOOL_BY_NAMES(STAND_ANNOY_CONFIG.knifeNames)
    if not tool then
        warn("Annoy failed -> no knife found")
        return false
    end

    local tRoot = getRoot(getWorldCharacter(target))
    local myRoot = getRoot(LocalPlayer.Character)
    if not tRoot or not myRoot then return false end

    local stabPosition = tRoot.Position
        - (tRoot.CFrame.LookVector * STAND_ANNOY_CONFIG.knifeDistance)
        + Vector3.new(0, STAND_ANNOY_CONFIG.knifeHeight, 0)
    setRootStableCFrame(myRoot, CFrame.new(stabPosition, tRoot.Position))
    task.wait(0.05)
    pcall(function() tool:Activate() end)
    task.wait(STAND_ANNOY_CONFIG.knifeRetryDelay)

    return STAND_VALUE_DROPPED(beforeValue, STAND_GET_TARGET_COMBINED_VALUE(target))
end

function STAND_ANNOY_REVOLVER_ONCE(target)
    local beforeValue = STAND_GET_TARGET_COMBINED_VALUE(target)
    local started = time()

    repeat
        if not STAND_TARGET_READY_TO_ANNOY(target) then
            return true
        end

        local tool = STAND_EQUIP_TOOL_BY_NAMES(STAND_ANNOY_CONFIG.revolverNames)
        if not tool then
            warn("Annoy failed -> no revolver found")
            return false
        end

        if tool and not toolHasAmmo(tool) then
            pressReloadKey()
            task.wait(0.25)
        end

        local tRoot = getRoot(getWorldCharacter(target))
        local myRoot = getRoot(LocalPlayer.Character)
        local aimPos, aimPart = getAimPosition(target)
        if not tRoot or not myRoot or not aimPos then return false end

        local angle = math.rad(math.random(0, 359))
        local offset = Vector3.new(
            math.cos(angle) * STAND_ANNOY_CONFIG.revolverRadius,
            STAND_ANNOY_CONFIG.revolverHeight,
            math.sin(angle) * STAND_ANNOY_CONFIG.revolverRadius
        )
        local targetPos = getClearCloseGunPosition(tRoot, aimPos, target, tRoot.Position + offset, math.random(0, 7))
        setRootStableCFrame(myRoot, CFrame.new(targetPos, aimPos))
        aimAtTarget(target, aimPos, aimPart)
        task.wait(0.04)
        pcall(function() tool:Activate() end)
        task.wait(STAND_ANNOY_CONFIG.revolverRetryDelay)

        if STAND_VALUE_DROPPED(beforeValue, STAND_GET_TARGET_COMBINED_VALUE(target)) then
            return true
        end
    until time() - started >= STAND_ANNOY_CONFIG.actionTimeout

    return false
end

function STAND_RUN_ANNOY_ACTION(target)
    if STAND_ANNOY.busy or not STAND_TARGET_READY_TO_ANNOY(target) then return end

    STAND_ANNOY.busy = true
    local thisToken = STAND_ANNOY.token

    task.spawn(function()
        local ok = pcall(function()
            local restoreFollow = isFollowing
            local resumeFollowToken = followResumeToken
            local action = STAND_ANNOY.nextAction

            if gkillEnabled then
                stopGunKill(false)
            end
            stopSafeSpotSwitching()
            stopStrafing()
            if restoreFollow then
                clearFollow()
                resumeFollowToken = followResumeToken
            end

            local hit = false
            if action == "knife" then
                hit = STAND_ANNOY_KNIFE_ONCE(target)
            else
                hit = STAND_ANNOY_REVOLVER_ONCE(target)
            end

            if hit then
                STAND_ANNOY.nextAction = action == "knife" and "revolver" or "knife"
            end

            if restoreFollow
                and thisToken == STAND_ANNOY.token
                and resumeFollowToken == followResumeToken
                and not gkillEnabled
                and not loopkillEnabled then
                returnToMainFollow()
            end
        end)

        if not ok then
            warn("Annoy action failed")
        end
        if thisToken == STAND_ANNOY.token then
            STAND_ANNOY.busy = false
        end
    end)
end

function STAND_START_ANNOY(target)
    if not target or target == LocalPlayer then return false end

    STAND_ANNOY.token += 1
    STAND_ANNOY.enabled = true
    STAND_ANNOY.target = target
    STAND_ANNOY.targetName = target.Name
    STAND_ANNOY.busy = false
    setSelectedTarget(target)
    print("Annoy started -> " .. target.Name)
    return true
end

function STAND_STOP_ANNOY()
    STAND_ANNOY.token += 1
    STAND_ANNOY.enabled = false
    STAND_ANNOY.target = nil
    STAND_ANNOY.targetName = nil
    STAND_ANNOY.busy = false
    print("Annoy stopped")
end

function STAND_UPDATE_ANNOY()
    if not STAND_ANNOY.enabled or STAND_ANNOY.busy then return end

    if (not STAND_ANNOY.target or STAND_ANNOY.target.Parent ~= Players) and STAND_ANNOY.targetName then
        STAND_ANNOY.target = Players:FindFirstChild(STAND_ANNOY.targetName)
    end

    if STAND_TARGET_READY_TO_ANNOY(STAND_ANNOY.target) then
        STAND_RUN_ANNOY_ACTION(STAND_ANNOY.target)
    end
end


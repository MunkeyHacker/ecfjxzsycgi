function fling(target)
    if flingBusy or not target or target == LocalPlayer then return false end

    task.spawn(function()
        flingBusy = true

        local character = LocalPlayer.Character
        local humanoid = getHumanoid(character)
        local rootPart = humanoid and humanoid.RootPart

        local function getFlingCharacter(plr)
            local directCharacter = plr and plr.Character
            if directCharacter and directCharacter.Parent then
                return directCharacter
            end

            local workspacePlayers = Workspace:FindFirstChild("Players")
            return (workspacePlayers and plr and workspacePlayers:FindFirstChild(plr.Name)) or directCharacter
        end

        local targetCharacter = getFlingCharacter(target)
        local targetHumanoid = getHumanoid(targetCharacter)
        local targetRoot = targetHumanoid and targetHumanoid.RootPart or getRoot(targetCharacter)
        local targetHead = targetCharacter and targetCharacter:FindFirstChild("Head")
        local accessory = targetCharacter and targetCharacter:FindFirstChildOfClass("Accessory")
        local handle = accessory and accessory:FindFirstChild("Handle")
        local basePart = targetRoot or targetHead or handle

        local function refreshTargetParts()
            targetCharacter = getFlingCharacter(target) or targetCharacter
            targetHumanoid = getHumanoid(targetCharacter)
            targetRoot = targetHumanoid and targetHumanoid.RootPart or getRoot(targetCharacter)
            targetHead = targetCharacter and targetCharacter:FindFirstChild("Head")
            accessory = targetCharacter and targetCharacter:FindFirstChildOfClass("Accessory")
            handle = accessory and accessory:FindFirstChild("Handle")
            basePart = targetRoot or targetHead or handle or basePart
            return targetCharacter and basePart
        end

        refreshTargetParts()

        if not character or not humanoid or not rootPart or not targetCharacter or not basePart then
            flingBusy = false
            return
        end

        if targetHumanoid and targetHumanoid.Sit then
            flingBusy = false
            return
        end

        local oldCFrame = rootPart.CFrame
        local oldCameraSubject = Workspace.CurrentCamera and Workspace.CurrentCamera.CameraSubject
        local bodyVelocity = Instance.new("BodyVelocity")
        local oldSeatedEnabled = true

        local function flingPosition(part, offset, angle)
            local velocity = part.AssemblyLinearVelocity
            local leadTime = math.clamp(velocity.Magnitude / 900, 0.035, 0.14)
            local cf = CFrame.new(part.Position + (velocity * leadTime)) * offset * angle
            rootPart.CFrame = cf
            character:SetPrimaryPartCFrame(cf)
            rootPart.Velocity = Vector3.new(9e7, 9e8, 9e7)
            rootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
        end

        local function resetPosition()
            local started = time()
            repeat
                rootPart.CFrame = oldCFrame * CFrame.new(0, 0.5, 0)
                character:SetPrimaryPartCFrame(oldCFrame * CFrame.new(0, 0.5, 0))
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                for _, part in ipairs(character:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.Velocity = Vector3.zero
                        part.RotVelocity = Vector3.zero
                    end
                end
                RunService.Heartbeat:Wait()
            until (rootPart.Position - oldCFrame.Position).Magnitude < 25 or time() - started > 1
        end

        pcall(function()
            oldFallenPartsDestroyHeight = Workspace.FallenPartsDestroyHeight
            Workspace.FallenPartsDestroyHeight = 0 / 0

            bodyVelocity.Parent = rootPart
            bodyVelocity.Velocity = Vector3.zero
            bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)

            oldSeatedEnabled = humanoid:GetStateEnabled(Enum.HumanoidStateType.Seated)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

            if Workspace.CurrentCamera then
                Workspace.CurrentCamera.CameraSubject = targetHead or handle or targetHumanoid or basePart
            end

            local started = time()
            local angle = 0
            repeat
                if not refreshTargetParts() then break end
                if not rootPart or not rootPart.Parent or not basePart or not basePart.Parent then break end
                angle += 100
                if basePart.Velocity.Magnitude < 50 then
                    local move = targetHumanoid and targetHumanoid.MoveDirection or Vector3.zero
                    local scaledMove = move * basePart.Velocity.Magnitude / 1.25
                    flingPosition(basePart, CFrame.new(0, 1.5, 0) + scaledMove, CFrame.Angles(math.rad(angle), 0, 0))
                    RunService.Heartbeat:Wait()
                    flingPosition(basePart, CFrame.new(0, -1.5, 0) + scaledMove, CFrame.Angles(math.rad(angle), 0, 0))
                    RunService.Heartbeat:Wait()
                    flingPosition(basePart, CFrame.new(0, 1.5, 0) + move, CFrame.Angles(math.rad(angle), 0, 0))
                    RunService.Heartbeat:Wait()
                    flingPosition(basePart, CFrame.new(0, -1.5, 0) + move, CFrame.Angles(math.rad(angle), 0, 0))
                    RunService.Heartbeat:Wait()
                else
                    local walkSpeed = targetHumanoid and targetHumanoid.WalkSpeed or 16
                    flingPosition(basePart, CFrame.new(0, 1.5, walkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                    RunService.Heartbeat:Wait()
                    flingPosition(basePart, CFrame.new(0, -1.5, -walkSpeed), CFrame.Angles(0, 0, 0))
                    RunService.Heartbeat:Wait()
                    flingPosition(basePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                    RunService.Heartbeat:Wait()
                    flingPosition(basePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                    RunService.Heartbeat:Wait()
                end
            until time() - started >= FLING_DURATION or not target.Parent or not flingBusy
        end)

        pcall(function() bodyVelocity:Destroy() end)
        pcall(function() humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, oldSeatedEnabled) end)
        pcall(function() Workspace.FallenPartsDestroyHeight = oldFallenPartsDestroyHeight end)
        if Workspace.CurrentCamera and oldCameraSubject then
            Workspace.CurrentCamera.CameraSubject = oldCameraSubject
        end
        resetPosition()

        flingBusy = false
    end)

    return true
end

-- ====================== FLYING MODULE STYLE ANIMATIONS ======================
local animConnection = nil
local flyAnimTracks = {}
local activeFlyAnim = nil
local savedAutoRotate = nil
local savedPlatformStand = nil
local lastTrackStop = 0
local lastFlyAnimPosition = nil

function STAND_GET_ANIMATION_TRACKS(humanoid)
    if not humanoid then return {} end

    local collected = {}
    local seen = {}
    local function collectTracks(tracks)
        if type(tracks) ~= "table" then return end
        for _, trackObj in ipairs(tracks) do
            if trackObj and not seen[trackObj] then
                seen[trackObj] = true
                table.insert(collected, trackObj)
            end
        end
    end

    local ok, tracks = pcall(function()
        if humanoid.GetPlayingAnimationTracks then
            return humanoid:GetPlayingAnimationTracks()
        end
        return nil
    end)
    if ok then
        collectTracks(tracks)
    end

    local animator = nil
    pcall(function()
        animator = humanoid:FindFirstChildOfClass("Animator")
    end)
    if not animator then return collected end

    ok, tracks = pcall(function()
        if animator.GetPlayingAnimationTracks then
            return animator:GetPlayingAnimationTracks()
        end
        return nil
    end)
    if ok then
        collectTracks(tracks)
    end

    return collected
end

function STAND_LOAD_ANIMATION(humanoid, anim)
    if not humanoid or not anim then return nil end

    local animator = nil
    pcall(function()
        animator = humanoid:FindFirstChildOfClass("Animator")
        if not animator then
            animator = Instance.new("Animator")
            animator.Parent = humanoid
        end
    end)

    if animator then
        local ok, trackObj = pcall(function()
            if animator.LoadAnimation then
                return animator:LoadAnimation(anim)
            end
            return nil
        end)
        if ok and trackObj then
            return trackObj
        end
    end

    local ok, trackObj = pcall(function()
        if humanoid.LoadAnimation then
            return humanoid:LoadAnimation(anim)
        end
        return nil
    end)
    if ok and trackObj then
        return trackObj
    end

    return nil
end

function STAND_PLAY_TRACK(trackObj, fadeTime, weight, speed)
    if not trackObj then return false end
    local played = false
    local ok = pcall(function()
        if trackObj.Play then
            trackObj:Play(fadeTime or 0.12, weight or 1, speed or 1)
            played = true
        end
    end)
    return ok and played
end

function STAND_STOP_TRACK(trackObj, fadeTime)
    if not trackObj then return end
    pcall(function()
        if trackObj.Stop then
            trackObj:Stop(fadeTime or 0.1)
        end
    end)
end

function STAND_DESTROY_INSTANCE(obj)
    if not obj then return end
    pcall(function()
        if obj.Destroy then
            obj:Destroy()
        end
    end)
end

function STAND_GET_TRACK_TIME(trackObj)
    local value = 0
    pcall(function()
        if trackObj and trackObj.TimePosition ~= nil then
            value = trackObj.TimePosition
        end
    end)
    return tonumber(value) or 0
end

function STAND_SET_TRACK_TIME(trackObj, timePosition)
    if not trackObj or timePosition == nil then return end
    pcall(function()
        trackObj.TimePosition = timePosition
    end)
end

function STAND_GET_TRACK_SPEED(trackObj)
    local value = 1
    pcall(function()
        if trackObj and trackObj.Speed ~= nil then
            value = trackObj.Speed
        end
    end)
    return tonumber(value) or 1
end

function STAND_SET_TRACK_SPEED(trackObj, speed)
    if not trackObj then return end
    speed = tonumber(speed) or 1
    pcall(function()
        if trackObj.AdjustSpeed then
            trackObj:AdjustSpeed(speed)
        end
    end)
end

function STAND_IS_TRACK_PLAYING(trackObj)
    local playing = false
    pcall(function()
        playing = trackObj and trackObj.IsPlaying == true
    end)
    return playing
end

function STAND_GET_TRACK_NAME(trackObj)
    local trackName = ""
    pcall(function()
        trackName = tostring((trackObj and trackObj.Name) or "")
    end)
    return trackName
end

function STAND_GET_TRACK_NUMBER(trackObj, fieldName, fallback)
    local value = fallback
    pcall(function()
        if trackObj and trackObj[fieldName] ~= nil then
            value = trackObj[fieldName]
        end
    end)
    return tonumber(value) or fallback
end

function STAND_GET_TRACK_ANIMATION_ID(trackObj)
    local candidates = {}
    local function addCandidate(value)
        if value ~= nil then
            table.insert(candidates, value)
        end
    end

    pcall(function()
        local anim = trackObj and trackObj.Animation
        if anim then
            addCandidate(anim.AnimationId)
            addCandidate(anim.Name)
        end
    end)
    pcall(function()
        addCandidate(trackObj and trackObj.AnimationId)
    end)
    addCandidate(STAND_GET_TRACK_NAME(trackObj))
    pcall(function()
        if trackObj and trackObj.GetDescendants then
            for _, obj in ipairs(trackObj:GetDescendants()) do
                if obj:IsA("Animation") then
                    addCandidate(obj.AnimationId)
                    addCandidate(obj.Name)
                end
            end
        end
    end)

    for _, candidate in ipairs(candidates) do
        local id = STAND_NORMALIZE_ANIMATION_ID(candidate)
        if id then
            return id
        end
    end

    return nil
end

function STAND_GET_TRACK_PRIORITY_SCORE(trackObj)
    local score = 0
    pcall(function()
        local priority = trackObj and trackObj.Priority
        local text = tostring(priority or ""):lower()
        if text:find("action", 1, true) then
            score = 80
        elseif text:find("movement", 1, true) then
            score = 10
        elseif text:find("idle", 1, true) then
            score = 5
        elseif priority and priority.Value then
            score = math.clamp(tonumber(priority.Value) or 0, 0, 10) * 8
        end
    end)
    return score
end

function stopFlyAnimTracks()
    for _, trackObj in pairs(flyAnimTracks) do
        if STAND_IS_TRACK_PLAYING(trackObj) then
            STAND_STOP_TRACK(trackObj, 0.1)
        end
    end
    activeFlyAnim = nil
end

function stopConflictingAnimTracks(humanoid)
    if not humanoid then return end
    for _, trackObj in ipairs(STAND_GET_ANIMATION_TRACKS(humanoid)) do
        local trackName = STAND_GET_TRACK_NAME(trackObj)
        local isStandEmote = trackObj == STAND_ACTIVE_EMOTE_TRACK
            or trackName:find("StandEmote_", 1, true) == 1
        if not FLY_ANIM_TRACK_NAMES[trackName] and not isStandEmote then
            STAND_STOP_TRACK(trackObj, 0.1)
        end
    end
end

function setFlyAnimationMode(char, enabled)
    local humanoid = getHumanoid(char)
    local animate = char and char:FindFirstChild("Animate")

    if animate and animate:IsA("LocalScript") then
        pcall(function()
            animate.Disabled = enabled
        end)
    end

    if humanoid then
        if enabled then
            if savedAutoRotate == nil then
                savedAutoRotate = humanoid.AutoRotate
            end
            if savedPlatformStand == nil then
                savedPlatformStand = humanoid.PlatformStand
            end
            pcall(function()
                humanoid.AutoRotate = false
                humanoid.PlatformStand = true
            end)

            if time() - lastTrackStop > 0.45 then
                stopConflictingAnimTracks(humanoid)
                lastTrackStop = time()
            end
        else
            if savedAutoRotate ~= nil then
                pcall(function()
                    humanoid.AutoRotate = savedAutoRotate
                end)
                savedAutoRotate = nil
            end
            if savedPlatformStand ~= nil then
                pcall(function()
                    humanoid.PlatformStand = savedPlatformStand
                end)
                savedPlatformStand = nil
            end
        end
    end
end

function playFlyAnimation(animName)
    if animName == activeFlyAnim then return end

    if activeFlyAnim and flyAnimTracks[activeFlyAnim] then
        STAND_STOP_TRACK(flyAnimTracks[activeFlyAnim], 0.1)
    end

    activeFlyAnim = animName
    local trackObj = flyAnimTracks[animName]
    if trackObj then
        STAND_PLAY_TRACK(trackObj, 0.1, 1, 1)
    end
end

function STAND_STOP_EMOTE(skipRefresh)
    if STAND_ACTIVE_EMOTE_TRACK then
        STAND_STOP_TRACK(STAND_ACTIVE_EMOTE_TRACK, 0.12)
        STAND_DESTROY_INSTANCE(STAND_ACTIVE_EMOTE_TRACK)
    end
    STAND_ACTIVE_EMOTE_TRACK = nil
    STAND_ACTIVE_EMOTE_NAME = nil
    if not skipRefresh and refreshCustomAnimation then
        task.defer(refreshCustomAnimation)
    end
end

function STAND_NORMALIZE_ANIMATION_ID(animationId)
    local idText = tostring(animationId or ""):match("%d+")
    return idText and tonumber(idText) or nil
end

function STAND_GET_EMOTE_ID(emoteName)
    emoteName = tostring(emoteName or ""):lower()
    local entry = STAND_EMOTE_LIBRARY[emoteName]
    if type(entry) == "table" then
        return entry[math.random(1, #entry)]
    end
    return entry
end

function STAND_EMOTE_ENTRY_HAS_ID(entry, emoteId)
    emoteId = tonumber(emoteId)
    if not emoteId then return false end
    if type(entry) == "table" then
        for _, id in ipairs(entry) do
            if tonumber(id) == emoteId then
                return true
            end
        end
        return false
    end
    return tonumber(entry) == emoteId
end

function STAND_GET_EMOTE_NAME_FOR_ID(emoteId)
    for emoteName, entry in pairs(STAND_EMOTE_LIBRARY) do
        if STAND_EMOTE_ENTRY_HAS_ID(entry, emoteId) then
            return emoteName
        end
    end
    return nil
end

function STAND_GET_EMOTE_LIST_TEXT()
    local names = {}
    for emoteName in pairs(STAND_EMOTE_LIBRARY) do
        table.insert(names, emoteName)
    end
    table.sort(names)
    return table.concat(names, ", ")
end

function STAND_PLAY_EMOTE(emoteName)
    local emoteId = STAND_GET_EMOTE_ID(emoteName)
    if not emoteId then
        print("Emotes: " .. STAND_GET_EMOTE_LIST_TEXT())
        return false
    end

    local char = LocalPlayer.Character
    local humanoid = getHumanoid(char)
    if not char or not humanoid then return false end

    STAND_STOP_EMOTE()
    stopConflictingAnimTracks(humanoid)
    stopFlyAnimTracks()

    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. tostring(emoteId)
    local trackObj = STAND_LOAD_ANIMATION(humanoid, anim)
    if not trackObj then
        return false
    end

    trackObj.Name = "StandEmote_" .. tostring(emoteName)
    trackObj.Looped = true
    pcall(function()
        trackObj.Priority = Enum.AnimationPriority.Action
    end)
    STAND_ACTIVE_EMOTE_TRACK = trackObj
    STAND_ACTIVE_EMOTE_NAME = tostring(emoteName):lower()
    if not STAND_PLAY_TRACK(trackObj, 0.12, 1, 1) then
        STAND_ACTIVE_EMOTE_TRACK = nil
        STAND_ACTIVE_EMOTE_NAME = nil
        STAND_DESTROY_INSTANCE(trackObj)
        return false
    end
    print("Emote -> " .. STAND_ACTIVE_EMOTE_NAME)
    return true
end

function getFlyAnimationName(root)
    local position = root.Position
    local delta = lastFlyAnimPosition and (position - lastFlyAnimPosition) or Vector3.zero
    lastFlyAnimPosition = position

    local flatDelta = Vector3.new(delta.X, 0, delta.Z)
    if flatDelta.Magnitude <= 0.08 then
        return "Idle"
    end

    local localMove = root.CFrame:VectorToObjectSpace(flatDelta.Unit)
    if math.abs(localMove.X) > math.abs(localMove.Z) then
        return localMove.X > 0 and "Right" or "Left"
    end

    return localMove.Z < 0 and "Forward" or "Back"
end

function stopCustomAnimation()
    animConnection = disconnect(animConnection)
    setFlyAnimationMode(LocalPlayer.Character, false)
    stopFlyAnimTracks()
    flyAnimTracks = {}
    lastFlyAnimPosition = nil
end

function createCustomAnimation(char)
    stopCustomAnimation()

    local humanoid = getHumanoid(char)
    if not humanoid then return end

    for animName, animId in pairs(FLY_ANIM_IDS) do
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://" .. tostring(animId)
        local trackObj = STAND_LOAD_ANIMATION(humanoid, anim)
        if trackObj then
            trackObj.Name = animName
            flyAnimTracks[animName] = trackObj
        end
    end

    animConnection = track(RunService.Heartbeat:Connect(function()
        local useSafeSpotAnim = safeSpotConnection ~= nil
        local useFollowAnim = isFlying and isFollowing and not gkillEnabled
        local useFlyAnim = useSafeSpotAnim or useFollowAnim or activelyStrafing
        local root = getRoot(char)
        if STAND_ACTIVE_EMOTE_TRACK then
            if useFlyAnim and root then
                setFlyAnimationMode(char, true)
            else
                setFlyAnimationMode(char, false)
            end
            stopFlyAnimTracks()
            if not STAND_IS_TRACK_PLAYING(STAND_ACTIVE_EMOTE_TRACK) then
                STAND_PLAY_TRACK(STAND_ACTIVE_EMOTE_TRACK, 0.12, 1, 1)
            end
            return
        end

        if not useFlyAnim or not root then
            setFlyAnimationMode(char, false)
            stopFlyAnimTracks()
            lastFlyAnimPosition = nil
            return
        end

        setFlyAnimationMode(char, true)
        if useSafeSpotAnim
            or (useFollowAnim and STAND_FOLLOW_ANIM_MODE == 3)
            or (useFollowAnim and STAND_FOLLOW_ANIM_MODE == 2)
            or (isFollowing and not followTargetMoving and not activelyStrafing) then
            lastFlyAnimPosition = root.Position
            playFlyAnimation("Idle")
        else
            playFlyAnimation(getFlyAnimationName(root))
        end
    end))
end

refreshCustomAnimation = function()
    local char = LocalPlayer.Character
    if char then
        savedAutoRotate = nil
        savedPlatformStand = nil
        createCustomAnimation(char)
    end
end

function releaseCharacterControl()
    stopCustomAnimation()
    savedAutoRotate = nil
    savedPlatformStand = nil

    local char = LocalPlayer.Character
    local humanoid = getHumanoid(char)
    local root = getRoot(char)
    local animate = char and char:FindFirstChild("Animate")

    if animate and animate:IsA("LocalScript") then
        pcall(function()
            animate.Disabled = false
        end)
    end

    if humanoid then
        pcall(function()
            humanoid.Sit = false
            humanoid.PlatformStand = false
            humanoid.AutoRotate = true
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end)
    end

    if root then
        root.AssemblyAngularVelocity = Vector3.zero
        root.AssemblyLinearVelocity = Vector3.zero
    end
end


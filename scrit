    if preferredName then
        local preferred = findInventoryTool(preferredName)
        if canUseGunCandidate(preferred, requireAmmo, skipName) then
            return preferred
        end
    end

    for _, tool in ipairs(getWeaponCandidates()) do
        if canUseGunCandidate(tool, requireAmmo, skipName) then
            return tool
        end
    end

    return nil
end

